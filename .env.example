# =============================================================================
# TRADINGO — Environment Variables
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────
APP_NAME=tradingo
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://tradingo:secret123@localhost:5432/tradingo?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS (S3 + CloudFront + SES) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=tradingo-uploads
CLOUDFRONT_DOMAIN=d1234.cloudfront.net
EMAIL_FROM=noreply@tradingo.io

# ─── OpenSearch ────────────────────────────────────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change-me
OPENSEARCH_REJECT_UNAUTHORIZED=true

# ─── ClickHouse ────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENABLED=false

# ─── Slack (Notifications) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Next.js (Frontend) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Razorpay (Payments) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Seed Admin ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@tradingo.io
SEED_ADMIN_PASSWORD=Admin@1234
