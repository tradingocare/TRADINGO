# =============================================================================
# TRADINGO — Environment Variables
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────
APP_NAME=tradingo
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://tradingo:secret123@localhost:5432/tradingo?schema=public
DIRECT_URL=postgresql://tradingo:secret123@localhost:5432/tradingo?schema=public
SHADOW_DATABASE_URL=postgresql://tradingo:secret123@localhost:5432/tradingo_shadow?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS (S3 + CloudFront + SES) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=tradingo-uploads
CLOUDFRONT_DOMAIN=d1234.cloudfront.net
EMAIL_FROM=noreply@tradingo.io

# ─── OpenSearch ────────────────────────────────────────────────────────────
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change-me
OPENSEARCH_REJECT_UNAUTHORIZED=true

# ─── ClickHouse ────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENABLED=false

# ─── Slack (Notifications) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── SMTP (Email) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── LinkedIn OAuth ────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ─── Google Maps ───────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ─── SMS (Twilio) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Next.js (Frontend) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Razorpay (Payments) ──────────────────────────────────────────────────
PAYMENT_MODE=test                                   # test | live
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Stripe (Payments — optional) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Seed Admin ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@tradingo.io
SEED_ADMIN_PASSWORD=Admin@1234

# ─── AI Gateway ─────────────────────────────────────────────────────────────
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=3600
AI_VAULT_MASTER_KEY=change-me-to-a-64-char-random-string-for-production

# ─── AI Providers — API Keys ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (Primary AI Provider)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google AI Studio (Gemini)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# Groq (Fast Inference)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Tavily (Live Search)
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com

# Firecrawl (Website Import)
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1
