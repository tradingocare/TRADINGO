{
  "name": "tradingo",
  "version": "1.0.0",
  "private": true,
  "description": "Tradingo monorepo",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docker:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:migrate": "pnpm --filter @tradingo/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @tradingo/api exec prisma studio",
    "db:generate": "pnpm --filter @tradingo/api exec prisma generate",
    "db:push": "pnpm --filter @tradingo/api exec prisma db push",
    "db:seed": "pnpm --filter @tradingo/api exec ts-node prisma/seed.ts",
    "db:seed:catalog": "pnpm exec ts-node --project prisma/seeds/tsconfig.json prisma/seeds/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
