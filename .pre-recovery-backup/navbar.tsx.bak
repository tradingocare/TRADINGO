'use client';

import { useState } from 'react';
import Link from 'next/link';
import { usePathname } from 'next/navigation';
import { motion, AnimatePresence } from 'framer-motion';
import { Menu, X, LogIn, UserPlus, Store, ShoppingBag } from 'lucide-react';
import { ThemeToggle } from './theme-toggle';
import { TradingoLogo } from './tradingo-logo';
import { cn } from '@/lib/utils';

interface NavItem {
  label: string;
  subtitle: string;
  href: string;
  icon?: React.ReactNode;
  cta?: boolean;
}

const NAV_ITEMS: NavItem[] = [
  { label: 'Trading', subtitle: 'Marketplace', href: '/products' },
  { label: 'GoLive', subtitle: 'For Buyers', href: '/login', icon: <ShoppingBag className="h-3.5 w-3.5" /> },
  { label: 'GoStart', subtitle: 'For Sellers', href: '/seller/login', icon: <Store className="h-3.5 w-3.5" /> },
  { label: 'GoJoin', subtitle: 'Create Account', href: '/register', icon: <UserPlus className="h-4 w-4" />, cta: true },
];

const PILL_SURFACE =
  'relative bg-[rgba(5,5,5,0.80)] backdrop-blur-[30px] ' +
  'border border-white/[0.08] rounded-full ' +
  'shadow-[0_15px_50px_rgba(0,0,0,0.55)]';

function Indicator({ active }: { active: boolean }) {
  return (
    <span
      aria-hidden
      className={cn(
        'block h-1.5 w-1.5 rounded-full transition-all duration-300',
        active ? 'bg-brand-300 animate-nav-active-pulse' : 'bg-white/35 group-hover:bg-brand-300/70'
      )}
    />
  );
}

export function Navbar() {
  const pathname = usePathname();
  const [mobileOpen, setMobileOpen] = useState(false);

  const isActive = (href: string) =>
    href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');

  return (
    <header className="sticky top-0 z-50 w-full px-3 pt-3 sm:px-4 sm:pt-4">
      <nav
        className={cn(
          PILL_SURFACE,
          'mx-auto flex w-full max-w-7xl items-center justify-between gap-2 pl-3 pr-2 sm:gap-4 sm:pl-4',
          'h-16 sm:h-[4.5rem]'
        )}
      >
        <span aria-hidden className="pointer-events-none absolute inset-0 overflow-hidden rounded-full">
          <span className="absolute inset-x-0 top-0 h-1/2 rounded-t-full bg-gradient-to-b from-white/[0.07] to-transparent" />
          <span className="animate-nav-shine absolute inset-y-0 left-0 w-1/3 bg-gradient-to-r from-transparent via-white/[0.08] to-transparent" />
          <span className="absolute inset-x-6 bottom-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" />
        </span>

        <Link
          href="/"
          aria-label="TRADINGO — home"
          className="group relative z-10 flex h-full w-[140px] shrink-0 items-center sm:w-[180px] md:w-[200px]"
        >
          <TradingoLogo height={46} showText light priority />
        </Link>

        <span
          aria-hidden
          className="relative z-10 hidden h-9 w-px self-center bg-gradient-to-b from-white/0 via-white/15 to-white/0 md:block"
        />

        <ul className="relative z-10 hidden flex-1 items-center justify-end gap-1 md:flex lg:gap-1.5">
          {NAV_ITEMS.map((item) => {
            const active = isActive(item.href);

            if (item.cta) {
              return (
                <li key={item.href} className="flex items-center pl-2 lg:pl-3">
                  <Link
                    href={item.href}
                    className={cn(
                      'group relative flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition-all duration-300',
                      'bg-brand-200 text-[#0a2540]',
                      'hover:bg-brand-300 hover:shadow-[0_0_30px_rgba(219,241,253,0.45)] hover:scale-105',
                      active && 'ring-2 ring-brand-400'
                    )}
                  >
                    <span className="flex items-center gap-1.5">
                      {item.icon}
                      {item.label}
                    </span>
                  </Link>
                </li>
              );
            }

            return (
              <li key={item.href} className="flex items-center">
                <Link
                  href={item.href}
                  className={cn(
                    'group relative flex items-center gap-2 rounded-full px-3 py-2 transition-all duration-300',
                    'hover:scale-105 hover:bg-white/[0.04] hover:shadow-[0_0_20px_rgba(219,241,253,0.15)]',
                    active && 'bg-white/[0.05]'
                  )}
                >
                  <Indicator active={active} />

                  <span className="flex flex-col leading-tight">
                    <span className="flex items-center gap-1.5">
                      {item.icon && (
                        <span className="text-white/50 group-hover:text-brand-300 transition-colors duration-300">
                          {item.icon}
                        </span>
                      )}
                      <span
                        className={cn(
                          'text-sm font-semibold tracking-tight transition-colors duration-300',
                          active ? 'text-brand-300' : 'text-white group-hover:text-brand-300'
                        )}
                      >
                        {item.label}
                      </span>
                    </span>
                    <span className="hidden text-[10px] font-medium uppercase tracking-[0.14em] text-white/55 lg:block">
                      {item.subtitle}
                    </span>
                  </span>

                  {active && (
                    <motion.span
                      layoutId="nav-active-underline"
                      className="animate-nav-underline absolute -bottom-0.5 left-1/2 h-[2px] w-6 -translate-x-1/2 rounded-full"
                      transition={{ type: 'spring', stiffness: 380, damping: 30 }}
                    />
                  )}
                </Link>
              </li>
            );
          })}
        </ul>

        <div className="relative z-10 flex items-center gap-1">
          <div className="hidden sm:block">
            <ThemeToggle />
          </div>
          <button
            type="button"
            onClick={() => setMobileOpen((v) => !v)}
            aria-label="Toggle menu"
            aria-expanded={mobileOpen}
            className={cn(
              'flex h-10 w-10 items-center justify-center rounded-full text-white transition-all duration-300',
              'hover:scale-105 hover:bg-white/[0.06] md:hidden'
            )}
          >
            {mobileOpen ? <X className="h-5 w-5" /> : <Menu className="h-5 w-5" />}
          </button>
        </div>
      </nav>

      <AnimatePresence>
        {mobileOpen && (
          <motion.div
            key="mobile-pill"
            initial={{ opacity: 0, y: -8 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -8 }}
            transition={{ duration: 0.25, ease: 'easeOut' }}
            className={cn(PILL_SURFACE, 'mx-auto mt-2 w-full max-w-7xl overflow-hidden p-2 md:hidden')}
          >
            <div className="flex flex-col gap-1 px-1 py-1">
              {NAV_ITEMS.map((item) => {
                const active = isActive(item.href);

                if (item.cta) {
                  return (
                    <Link
                      key={item.href}
                      href={item.href}
                      onClick={() => setMobileOpen(false)}
                      className={cn(
                        'flex items-center justify-center gap-2 rounded-full px-4 py-3 text-sm font-bold transition-all duration-300',
                        'bg-brand-200 text-[#0a2540]',
                        'hover:bg-brand-300 active:scale-[0.98]'
                      )}
                    >
                      {item.icon}
                      <span>{item.label}</span>
                      <span className="text-[10px] font-medium uppercase tracking-wider opacity-60">
                        — {item.subtitle}
                      </span>
                    </Link>
                  );
                }

                return (
                  <Link
                    key={item.href}
                    href={item.href}
                    onClick={() => setMobileOpen(false)}
                    className={cn(
                      'group flex items-center gap-3 rounded-full px-3.5 py-3 transition-all duration-300',
                      'hover:bg-white/[0.04]',
                      active && 'bg-white/[0.05]'
                    )}
                  >
                    <Indicator active={active} />
                    <span className="flex flex-col leading-tight">
                      <span className="flex items-center gap-2">
                        {item.icon && (
                          <span className="text-white/50">{item.icon}</span>
                        )}
                        <span
                          className={cn(
                            'text-sm font-semibold',
                            active ? 'text-brand-300' : 'text-white'
                          )}
                        >
                          {item.label}
                        </span>
                      </span>
                      <span className="text-[10px] uppercase tracking-[0.14em] text-white/50">
                        {item.subtitle}
                      </span>
                    </span>
                  </Link>
                );
              })}
            </div>
            <div className="mt-1 flex items-center justify-between border-t border-white/[0.06] px-2 pb-1 pt-3">
              <span className="text-[10px] uppercase tracking-[0.2em] text-white/35">Menu</span>
              <ThemeToggle />
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </header>
  );
}
