{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyPublicRead",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::tradingo-uploads/*",
      "Condition": {
        "StringNotEquals": {
          "aws:sourceVpce": "${VPCE_ID}"
        }
      }
    },
    {
      "Sid": "AllowCloudFrontOAI",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::cloudfront:user/CloudFront Origin Access Identity ${OAI_ID}"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::tradingo-uploads/*"
    },
    {
      "Sid": "AllowEncryptedUploads",
      "Effect": "Allow",
      "Principal": {
        "AWS": "${APP_IAM_ROLE}"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::tradingo-uploads/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    },
    {
      "Sid": "DenyIncorrectEncryption",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::tradingo-uploads/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    }
  ]
}
