# ─────────────────────────────────────────────────────────────────────────────
# TRADINGO Terraform Variables (Example)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in real values.
# For production, store secrets in AWS Secrets Manager or a secure vault.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Region ────────────────────────────────────────────────────
environment = "production"
aws_region  = "ap-south-1"
aws_profile = "tradingo-prod"

# ── Networking ──────────────────────────────────────────────────────────────
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b", "ap-south-1c"]

# ── Database (RDS PostgreSQL) ───────────────────────────────────────────────
db_instance_class         = "db.r6g.large"
db_allocated_storage      = 100
db_max_allocated_storage  = 500
db_backup_retention_days  = 35
db_multi_az               = true
db_deletion_protection    = true

# ── Redis (ElastiCache) ─────────────────────────────────────────────────────
redis_node_type        = "cache.r6g.large"
redis_num_cache_clusters = 3
redis_multi_az         = true

# ── OpenSearch ──────────────────────────────────────────────────────────────
opensearch_instance_type          = "r6g.large.search"
opensearch_instance_count         = 3
opensearch_ebs_volume_size        = 100
opensearch_dedicated_master_enabled = true
opensearch_dedicated_master_count = 3

# ── ECS Fargate ─────────────────────────────────────────────────────────────
ecs_web_cpu       = 1024
ecs_web_memory    = 2048
ecs_api_cpu       = 2048
ecs_api_memory    = 4096

web_desired_count = 2
web_max_count     = 10
api_desired_count = 2
api_max_count     = 10

# ── DNS & Certificates ──────────────────────────────────────────────────────
domain_name                = "tradingo.io"
certificate_arn            = "arn:aws:acm:ap-south-1:123456789012:certificate/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
api_certificate_arn        = "arn:aws:acm:ap-south-1:123456789012:certificate/ffffffff-gggg-hhhh-iiii-jjjjjjjjjjjj"
cloudfront_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/kkkkkkkk-llll-mmmm-nnnn-oooooooooooo"
route53_zone_id            = "Z0123456789ABCDEFGHIJ"

# ── CloudFront & WAF ────────────────────────────────────────────────────────
geo_allowed_countries = ["IN", "AE", "SA", "QA", "KW", "BH", "OM", "LB", "JO", "EG", "IQ", "YE", "PS"]
waf_rate_limit        = 5000

# ── Monitoring & Notifications ──────────────────────────────────────────────
sns_topic_arn                = "arn:aws:sns:ap-south-1:123456789012:tradingo-prod-alerts"
enable_container_insights    = true
log_retention_days           = 30

# ── Tags ────────────────────────────────────────────────────────────────────
tags = {
  CostCenter = "Engineering"
  Owner      = "Platform-Team"
  Repo       = "github.com/tradingo/tradingo"
}
