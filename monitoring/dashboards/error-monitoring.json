{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "TRADINGO - Error Monitoring",
  "uid": "tradingo-error-monitoring",
  "timezone": "utc",
  "panels": [
    { "id": 1, "title": "Error Rate by Endpoint", "type": "barchart", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "targets": [{ "expr": "topk(20, sum by(handler) (rate(http_requests_total{status=~\"5..\"}[5m])))", "legendFormat": "{{handler}}" }] },
    { "id": 2, "title": "Top 10 Error Messages", "type": "table", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }, "targets": [{ "expr": "topk(10, sum by(message) (rate(tradingo_errors_total[1h])))" }] },
    { "id": 3, "title": "Errors by Severity", "type": "piechart", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }, "targets": [{ "expr": "sum by(severity) (increase(tradingo_errors_total[24h]))" }] },
    { "id": 4, "title": "Errors Over Time", "type": "timeseries", "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 }, "targets": [{ "expr": "sum by(severity) (rate(tradingo_errors_total[5m]))" }] },
    { "id": 5, "title": "Errors by Service", "type": "barchart", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }, "targets": [{ "expr": "sum by(service) (rate(http_requests_total{status=~\"5..\"}[5m]))" }] },
    { "id": 6, "title": "Unhandled Rejections", "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 16 }, "targets": [{ "expr": "increase(tradingo_unhandled_rejections_total[1h])" }] },
    { "id": 7, "title": "Recent Errors", "type": "table", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 }, "targets": [{ "expr": "tradingo_errors_total offset 5m" }] }
  ]
}
