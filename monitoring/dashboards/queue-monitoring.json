{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "TRADINGO - Queue Monitoring",
  "uid": "tradingo-queue-monitoring",
  "timezone": "utc",
  "panels": [
    { "id": 1, "title": "Queue Depth by Name", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "targets": [{ "expr": "bull_queue_depth", "legendFormat": "{{queue}}" }] },
    { "id": 2, "title": "Job Processing Rate", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }, "targets": [{ "expr": "rate(bull_jobs_processed_total[5m])", "legendFormat": "{{queue}}" }] },
    { "id": 3, "title": "Job Duration p50", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }, "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(bull_job_duration_seconds_bucket[5m])) by (le, queue))", "legendFormat": "{{queue}}" }] },
    { "id": 4, "title": "Job Duration p95", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }, "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(bull_job_duration_seconds_bucket[5m])) by (le, queue))", "legendFormat": "{{queue}}" }] },
    { "id": 5, "title": "Failed Jobs", "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 }, "targets": [{ "expr": "sum(increase(bull_jobs_failed_total[1h]))", "legendFormat": "Failed" }] },
    { "id": 6, "title": "Stalled Jobs", "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 }, "targets": [{ "expr": "bull_jobs_stalled", "legendFormat": "Stalled" }] },
    { "id": 7, "title": "Active Workers", "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 }, "targets": [{ "expr": "bull_active_workers", "legendFormat": "Workers" }] },
    { "id": 8, "title": "Queue Health Score", "type": "stat", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 }, "targets": [{ "expr": "1 - (sum(increase(bull_jobs_failed_total[1h])) / sum(increase(bull_jobs_processed_total[1h])))", "legendFormat": "Health" }] },
    { "id": 9, "title": "Job Status Distribution", "type": "piechart", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 }, "targets": [
      { "expr": "bull_jobs_active", "legendFormat": "Active" },
      { "expr": "bull_jobs_waiting", "legendFormat": "Waiting" },
      { "expr": "bull_jobs_completed", "legendFormat": "Completed" },
      { "expr": "bull_jobs_failed", "legendFormat": "Failed" }
    ]}
  ]
}
