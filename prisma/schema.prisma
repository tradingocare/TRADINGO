// ─────────────────────────────────────────────────────
// RFQ + TRADMATCH — Phase 3A.7
// ─────────────────────────────────────────────────────

model Rfq {
  id              String        @id @default(uuid())
  companyId       String
  userId          String?
  categoryId      String?
  industryId      String?
  rfqNumber       String?       @unique
  stateCode       String?
  title           String
  description     String?
  rfqType         RfqType
  source          RfqSource     @default(DIRECT)
  sourceId        String?
  visibility      RfqVisibility  @default(PUBLIC)
  urgency         RfqUrgency     @default(NORMAL)
  status          RfqStatus      @default(DRAFT)
  budgetMin       Decimal?       @db.Decimal(14, 2)
  budgetMax       Decimal?       @db.Decimal(14, 2)
  showBudget      Boolean        @default(false)
  currency        String         @default("INR")
  quantity        Int?
  unit            String?
  preferredLocation String?
  deliveryAddress Json?
  paymentPreference String?
  expiresAt       DateTime?
  matchedCount    Int            @default(0)
  quoteCount      Int            @default(0)
  acceptedQuoteId String?        @unique
  convertedAt     DateTime?
  closedAt        DateTime?
  closedBy        String?
  reopenedAt      DateTime?
  reopenCount     Int            @default(0)
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?

  company         Company          @relation("BuyerRfqs", fields: [companyId], references: [id], onDelete: Restrict)
  user            User?            @relation("RfqCreators", fields: [userId], references: [id], onDelete: SetNull)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  industry        Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  locations       RfqLocation[]
  attachments     RfqAttachment[]
  productItems    RfqProductItem[]
  vendorMatches   RfqVendorMatch[]
  quotes          Quote[]          @relation("RfqQuotes")
  analyticsEvents RfqAnalyticsEvent[]
  orders          Order[]          @relation("RfqOrders")
  negotiations    Negotiation[]    @relation("NegotiationRfqs")

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([source, sourceId])
  @@index([categoryId, status, createdAt])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([rfqNumber])
