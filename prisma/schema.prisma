  QUALITY_ISSUE
  QUANTITY_ISSUE
  WRONG_PRODUCT
  LATE_DELIVERY
  PAYMENT_ISSUE
  SERVICE_ISSUE
  LOGISTICS_ISSUE
  DAMAGED_PRODUCT
  MISSING_ITEMS
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  EVIDENCE_PENDING
  NEGOTIATION
  ESCALATED
  ADMIN_ARBITRATION
  PARTIALLY_RESOLVED
  RESOLVED
  REFUNDED
  REJECTED
  CANCELLED
  EXPIRED
  APPEALED
}

enum ResolutionType {
  FULL_REFUND
  PARTIAL_REFUND
  REPLACEMENT
  PRICE_ADJUSTMENT
  SERVICE_REWORK
  NO_ACTION
}

model Dispute {
  id                String        @id @default(uuid())
  disputeNumber     String        @unique
  orderId           String
  escrowId          String?
  raisedByCompanyId String
  assignedAdminId String? // admin handling arbitration
  assignedAt DateTime? // when admin assigned
  arbitrationDueAt DateTime? // SLA deadline
  assignmentReason String? // e.g., round robin
  againstCompanyId  String
  type              DisputeType
  reason            DisputeReason
  status            DisputeStatus @default(OPEN)
  description       String
  amount            Int?
  currency          String        @default("INR")
  timeLimit         DateTime?
  filedAt           DateTime      @default(now())
  underReviewAt     DateTime?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  rejectedAt        DateTime?
  refundedAt        DateTime?
  cancelledAt       DateTime?
  expiredAt         DateTime?
  appealedAt        DateTime?
  createdBy         String
  updatedBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  order           Order             @relation(fields: [orderId], references: [id])
  escrow          Escrow?           @relation(fields: [escrowId], references: [id])
  raisedByCompany Company           @relation("DisputeRaisedBy", fields: [raisedByCompanyId], references: [id])
  againstCompany  Company           @relation("DisputeAgainst", fields: [againstCompanyId], references: [id])
  messages        DisputeMessage[]
  evidence        DisputeEvidence[]
  timeline        DisputeTimelineEvent[]
  resolution      DisputeResolution?
  appeal          DisputeAppeal?
  disputeProcessorExecutions DisputeProcessorExecution[]

  @@index([orderId])
  @@index([escrowId])
  @@index([raisedByCompanyId])
  @@index([againstCompanyId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedAdminId])
  @@index([assignedAt])
  @@index([arbitrationDueAt])
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  senderId    String
  content     String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender      User     @relation(fields: [senderId], references: [id])

  @@index([disputeId])
  @@index([createdAt])
}

model DisputeEvidence {
  id          String   @id @default(uuid())
  disputeId   String
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  uploadedBy  String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeTimelineEvent {
  id          String   @id @default(uuid())
  disputeId   String
  type        String
  description String?
  metadata    Json?
  createdBy   String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([createdAt])
}

model DisputeResolution {
  id              String         @id @default(uuid())
  disputeId       String         @unique
  resolutionType  ResolutionType
  description     String?
  refundAmount    Int?
  replacementInfo String?
  priceAdjustment Int?
  approvedBy      String
  approvedAt      DateTime       @default(now())
  executedAt      DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  dispute         Dispute        @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeProcessorExecution {
  id          String   @id @default(uuid())
  jobId       String   @unique
  disputeId   String
  type        String
  processedAt DateTime @default(now())
  dispute     Dispute @relation(fields: [disputeId], references: [id])

  @@index([disputeId])
  @@index([processedAt])
  @@unique([disputeId, type])
}

model DisputeAppeal {
  id              String        @id @default(uuid())
  disputeId       String        @unique
  reason          String
  supportingInfo  String?
  filedBy         String
  filedAt         DateTime      @default(now())
  status          String        @default("PENDING")
  reviewedBy      String?
  reviewedAt      DateTime?
  decision        String?
  decisionNotes   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  dispute         Dispute       @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

