  orderIds        Json?
  bankAccount     String?
  ifscCode        String?
  fundAccountId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([status])
