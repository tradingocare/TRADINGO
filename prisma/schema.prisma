model ProductDraft {
  id                String           @id @default(uuid())
  companyId         String
  categoryId        String?
  subcategoryId     String?
  name              String?
  slug              String?          @unique
  shortDescription  String?
  description       String?
  productType       ProductType?
  brand             String?
  model             String?
  sku               String?
  gtin              String?
  hsCode            String?
  moq               Int?
  unit              String?
  visibilityRadius  GeographicReach?
  latitude          Float?
  longitude         Float?
  isSampleOrder     Boolean          @default(false)
  samplePrice       Decimal?         @db.Decimal(12, 2)
  exportSupported   Boolean          @default(false)
  exportCountries   String[]
  step              Int              @default(1)
  totalSteps        Int              @default(7)
