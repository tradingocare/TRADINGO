model Escrow {
  id              String        @id @default(uuid())
  orderId         String        @unique
  buyerCompanyId  String
  sellerCompanyId String
  amount          Int
  goCashAmount    Int           @default(0)
  netAmount       Int
  status          EscrowStatus  @default(PENDING)
  heldAt          DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?
  disputedAt      DateTime?
  frozenAt        DateTime?
  disputedAmount  Int?
  autoReleaseAt   DateTime?
  manualReviewAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           Order         @relation(fields: [orderId], references: [id])
  buyerCompany    Company       @relation("EscrowBuyer", fields: [buyerCompanyId], references: [id])
  sellerCompany   Company       @relation("EscrowSeller", fields: [sellerCompanyId], references: [id])
  events          EscrowEvent[]
  settlements     Settlement[]
  disputes        Dispute[]

  @@index([orderId])
  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
}

model EscrowEvent {
  id          String          @id @default(uuid())
  escrowId    String
  type        EscrowEventType
  metadata    Json?
  createdById String
  createdAt   DateTime        @default(now())

  escrow      Escrow          @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([createdAt])
}

model Settlement {
  id              String            @id @default(uuid())
  escrowId        String
  amount          Int
  status          SettlementStatus  @default(PENDING)
  processedAt     DateTime?
  failedAt        DateTime?
  failedReason    String?
  retryCount      Int               @default(0)
  lastRetryAt     DateTime?
  settledAt       DateTime?
  createdById     String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  escrow          Escrow            @relation(fields: [escrowId], references: [id])
  events          SettlementEvent[]

  @@index([escrowId])
  @@index([status])
}

model SettlementEvent {
  id            String              @id @default(uuid())
  settlementId  String
  type          SettlementEventType
  metadata      Json?
  createdById   String
  createdAt     DateTime            @default(now())

  settlement    Settlement          @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([createdAt])
}

model ManualPaymentProof {
  id                  String                            @id @default(uuid())
  paymentId           String                            @unique
  utrNumber           String?
  transactionScreenshot String?
  transactionDate     DateTime?
  bankName            String?
  paymentMethod       ManualPaymentMethod
  amount              Int
  verifiedById        String?
  verifiedAt          DateTime?
  verificationStatus  ManualPaymentVerificationStatus    @default(PENDING)
  remarks             String?
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt

  companyId           String
  payment             Payment                           @relation(fields: [paymentId], references: [id])
  company             Company                           @relation(fields: [companyId], references: [id])
  verifiedBy          User?                             @relation(fields: [verifiedById], references: [id])

  @@index([paymentId])
  @@index([companyId])
  @@index([verificationStatus])
}

