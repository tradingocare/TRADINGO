  totalSteps        Int              @default(7)
  status            DraftStatus      @default(INCOMPLETE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  lastAutoSavedAt   DateTime?
  submittedAt       DateTime?
  createdBy         String
  updatedBy         String

  company          Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         Category?                     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  draftSpecs       ProductDraftSpec[]
  draftVariants    ProductDraftVariant[]
  draftMedia       ProductDraftMedia[]
  draftAttachments ProductDraftAttachment[]
  certifications   ProductDraftCertification[]
  multiLangDesc    ProductDraftMultiLangDesc[]
  priceSlabs       ProductDraftPriceSlab[]
  completeness     ProductCompletenessScore?

  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([createdBy])
  @@index([slug])
}

model ProductDraftSpec {
  id        String @id @default(uuid())
  draftId   String
  key       String
  value     String
  sortOrder Int    @default(0)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([key])
}

model ProductDraftVariant {
  id             String       @id @default(uuid())
  draftId        String
  variantType    VariantType
  customName     String?
  value          String
  sku            String?
  price          Decimal?     @db.Decimal(12, 2)
  compareAtPrice Decimal?     @db.Decimal(12, 2)
  currency       String       @default("INR")
  quantity       Int          @default(0)
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ProductDraftMedia {
  id        String    @id @default(uuid())
  draftId   String
  type      MediaType
  url       String
  title     String?
  altText   String?
  fileSize  Int?
  mimeType  String?
  isPrimary Boolean   @default(false)
  sortOrder Int       @default(0)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ProductDraftAttachment {
  id        String @id @default(uuid())
  draftId   String
  type      String
  url       String
  title     String?
  fileSize  Int?
  mimeType  String?
  sortOrder Int    @default(0)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ProductDraftCertification {
  id        String   @id @default(uuid())
  draftId   String
  type      String
  number    String?
  issuedBy  String?
  issuedAt  DateTime?
  expiresAt DateTime?
  fileUrl   String?
  verified  Boolean  @default(false)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ProductDraftMultiLangDesc {
  id               String @id @default(uuid())
  draftId          String
  locale           String
  name             String?
  shortDescription String?
  description      String?
  isPrimary        Boolean @default(false)

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, locale])
  @@index([draftId])
}

model ProductDraftPriceSlab {
  id       String  @id @default(uuid())
  draftId  String
  minQty   Int
  maxQty   Int?
  price    Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

model ProductCompletenessScore {
  id               String   @id @default(uuid())
  draftId          String   @unique
  total            Int      @default(0)
  basicInfo        Int      @default(0)
  specifications   Int      @default(0)
  media            Int      @default(0)
  pricing          Int      @default(0)
  variants         Int      @default(0)
  certifications   Int      @default(0)
  localization     Int      @default(0)
  logistics        Int      @default(0)
  lastCalculatedAt DateTime @default(now())

  draft ProductDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model AttributeTemplate {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category                    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fields   AttributeTemplateField[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([isActive])
}

model AttributeTemplateField {
  id             String    @id @default(uuid())
  templateId     String
  key            String
  label          String
  type           FieldType
  placeholder    String?
  helpText       String?
  defaultValue   String?
  options        String[]
  unit           String?
  minValue       Float?
  maxValue       Float?
  minLength      Int?
  maxLength      Int?
  required       Boolean   @default(false)
  conditionKey   String?
  conditionValue String?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  section        String?

  template AttributeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([key, templateId])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProductReview {
  id            String       @id @default(uuid())
  productId     String
  companyId     String?
  userId        String?
  rating        Int          // 1-5
  title         String?
  review        String?
  isVerifiedPurchase Boolean  @default(false)
  status        ReviewStatus @default(PENDING)
  helpfulCount  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
  @@index([rating])
}

model SavedProduct {
  id        String   @id @default(uuid())
  userId    String
  productId String
  notes     String?
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model ProductQa {
  id        String   @id @default(uuid())
  productId String
  companyId String?  // seller company that answers
  askedBy   String   // user ID
  question  String
  answer    String?
  answeredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([productId])
}

// ──────────────────────────────────────────────
// Phase 7D — Beta Company Onboarding Program
// ──────────────────────────────────────────────

enum BetaInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum FeedbackType {
  BUG
  FEATURE
  NPS
  GENERAL
}

enum FeedbackStatus {
  NEW
  REVIEWED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BetaOnboardingStep {
  INVITE_ACCEPTED
  PROFILE_SETUP
  COMPANY_VERIFICATION
  PRODUCT_SETUP
  RFQ_CONFIGURATION
  TEAM_INVITES
  INTEGRATION_SETUP
  GO_LIVE
  ONBOARDING_COMPLETE
}

model BetaProgram {
  id            String   @id @default(uuid())
  name          String
  description   String?
  maxCompanies  Int      @default(50)
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BetaInvite {
  id          String           @id @default(uuid())
  email       String
  companyName String?
  token       String           @unique
  status      BetaInviteStatus @default(PENDING)
  invitedById String?
  companyId   String?
  programId   String?
  message     String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([email])
  @@index([token])
  @@index([status])
  @@index([companyId])
}

model Feedback {
  id             String         @id @default(uuid())
  type           FeedbackType   @default(GENERAL)
  title          String?
  description    String?
  category       String?
  priority       String?
  score          Int?
  comment        String?
  businessImpact String?
  browserInfo    Json?
  status         FeedbackStatus @default(NEW)
  companyId      String?
  userId         String?
  page           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([type])
  @@index([status])
  @@index([companyId])
  @@index([createdAt])
}

model UsageEvent {
  id         String   @id @default(uuid())
  companyId  String
  userId     String?
  eventName  String
  category   String?
  properties Json?
  ip         String?
  userAgent  String?
  sessionId  String?
  timestamp  DateTime @default(now())

  @@index([companyId])
  @@index([eventName])
  @@index([category])
  @@index([timestamp])
  @@index([companyId, timestamp])
}

model ErrorEvent {
  id          String   @id @default(uuid())
  companyId   String?
  userId      String?
  errorType   String
  errorMessage String
  stackTrace  String?
  page        String?
  action      String?
  metadata    Json?
  ip          String?
  userAgent   String?
  resolved    Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([companyId])
  @@index([errorType])
  @@index([timestamp])
  @@index([resolved])
}

model SupportTicket {
  id          String         @id @default(uuid())
  companyId   String
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
}

model SupportTicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  userId      String
  message     String
  attachments Json?
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

model BetaMetrics {
  id          String   @id @default(uuid())
  companyId   String
  programId   String?
  metricName  String
  metricValue Float
  metadata    Json?
  recordedAt  DateTime @default(now())

  @@index([companyId])
  @@index([metricName])
  @@index([recordedAt])
  @@index([companyId, metricName])
}

model BetaCompanyProfile {
  id                    String             @id @default(uuid())
  companyId             String             @unique
  onboardingStep        BetaOnboardingStep @default(INVITE_ACCEPTED)
  onboardingCompletedAt DateTime?
  goLiveAt              DateTime?
  welcomeEmailSent      Boolean            @default(false)
  setupProgress         Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([companyId])
  @@index([onboardingStep])
}

// ──────────────────────────────────────────────
// Phase 7E — Public Launch Preparation
// ──────────────────────────────────────────────

enum ChecklistStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  DETECTED
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

model LaunchChecklistItem {
  id          String   @id @default(uuid())
  category    String
  label       String
  description String?
  isRequired  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statuses    LaunchChecklistStatus[]

  @@index([category])
  @@index([sortOrder])
}

model LaunchChecklistStatus {
  id          String         @id @default(uuid())
  itemId      String
  companyId   String?
  status      ChecklistStatus @default(NOT_STARTED)
  completedBy String?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  item        LaunchChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, companyId])
  @@index([itemId])
  @@index([status])
}

model Incident {
  id               String           @id @default(uuid())
  title            String
  description      String
  status           IncidentStatus   @default(DETECTED)
  severity         IncidentSeverity @default(MEDIUM)
  impactedServices String[]
  reportedBy       String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  updates          IncidentUpdate[]

  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model IncidentUpdate {
  id          String         @id @default(uuid())
  incidentId  String
  message     String
  status      IncidentStatus
  createdAt   DateTime       @default(now())

  incident    Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model ProductBestsellerSnapshot {
  id        String   @id @default(uuid())
  productId String
  companyId String
  weekStart DateTime
  weekEnd   DateTime
  rank      Int
  score     Float
  salesCount Int     @default(0)
  revenue   Float    @default(0)
  views     Int      @default(0)
  rfqs      Int      @default(0)
  quotes    Int      @default(0)
  conversionRate Float @default(0)
  trustScore      Int      @default(0)
  growthRate      Float    @default(0)
  city      String?
  state     String?
  country   String   @default("IN")
  createdAt DateTime @default(now())

  @@unique([productId, weekStart])
  @@index([weekStart])
  @@index([rank])
  @@index([productId])
  @@index([companyId])
  @@index([score])
}

model CategoryBestsellerSnapshot {
  id         String   @id @default(uuid())
  categoryId String
  weekStart  DateTime
  weekEnd    DateTime
  rank       Int
  score      Float
  productCount Int    @default(0)
  totalSales Int      @default(0)
  totalRevenue Float  @default(0)
  growthRate Float    @default(0)
  city       String?
  state      String?
  country    String   @default("IN")
  createdAt  DateTime @default(now())

  @@unique([categoryId, weekStart])
  @@index([weekStart])
  @@index([rank])
  @@index([categoryId])
  @@index([score])
}

model SellerBestsellerSnapshot {
  id        String   @id @default(uuid())
  companyId String
  weekStart DateTime
  weekEnd   DateTime
  rank      Int
  score     Float
  totalSales Int     @default(0)
  totalRevenue Float @default(0)
  totalProducts Int  @default(0)
  avgTrustScore Int  @default(0)
  responseRate Float @default(0)
  growthRate Float   @default(0)
  city      String?
  state     String?
  country   String   @default("IN")
  createdAt DateTime @default(now())

  @@unique([companyId, weekStart])
  @@index([weekStart])
  @@index([rank])
  @@index([companyId])
  @@index([score])
}

model CategoryTemplate {
  id         String           @id @default(uuid())
  categoryId String
  name       String
  version    Int              @default(1)
  status     TemplateStatus   @default(DRAFT)
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  category Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sections TemplateSection[]

  @@unique([categoryId, version])
  @@index([categoryId])
  @@index([status])
}

model TemplateSection {
  id          String   @id @default(uuid())
  templateId  String
  key         String
  title       String
  description String?
  sortOrder   Int      @default(0)
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template CategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields   TemplateField[]

  @@unique([templateId, key])
  @@index([templateId])
}

model TemplateField {
  id           String            @id @default(uuid())
  sectionId    String
  key          String
  label        String
  type         TemplateFieldType
  placeholder  String?
  helpText     String?
  defaultValue Json?
  options      Json?
  unit         String?
  validation   Json?
  visibility   Json?
  metadata     Json?
  sortOrder    Int               @default(0)
  isRequired   Boolean           @default(false)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  section           TemplateSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  productAttributes ProductAttribute[]

  @@unique([sectionId, key])
  @@index([sectionId])
  @@index([key])
}

model ProductAttribute {
  id        String   @id @default(uuid())
  productId String
  fieldId   String
  fieldKey  String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  field   TemplateField @relation(fields: [fieldId], references: [id])

  @@unique([productId, fieldId])
  @@unique([productId, fieldKey])
  @@index([productId])
  @@index([fieldId])
}

model ProductLocationIndex {
  id              String         @id @default(uuid())
  productId       String         @unique
  companyId       String
  categoryId      String?
  latitude        Float
  longitude       Float
  visibilityRadius GeographicReach
  trustScore      Int            @default(0)
  price           Decimal?       @db.Decimal(12, 2)
  isVerified      Boolean        @default(false)
  isTradgo        Boolean        @default(false)
  moq             Int            @default(1)
  deliveryEta     String?
  status          ProductStatus
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([latitude, longitude])
  @@index([companyId])
  @@index([categoryId])
  @@index([visibilityRadius])
  @@index([status])
  @@index([trustScore])
  @@index([isVerified])
  @@index([isTradgo])
  @@index([price])
}
