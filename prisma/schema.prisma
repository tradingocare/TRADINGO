  updatedAt       DateTime       @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([latitude, longitude])
  @@index([companyId])
  @@index([categoryId])
  @@index([visibilityRadius])
  @@index([status])
  @@index([trustScore])
  @@index([isVerified])
  @@index([isTradgo])
  @@index([price])
}

model ProductApproval {
  id         String                 @id @default(uuid())
  productId  String
  action     ProductApprovalAction
  reviewerId String?
  reason     String?
  createdAt  DateTime               @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewer User?  @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([reviewerId])
  @@index([createdAt])
}

model ProductBrand {
  id          String      @id @default(uuid())
  companyId   String
  name        String
  slug        String      @unique
  logo        String?
  description String?
  status      BrandStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([companyId])
  @@index([slug])
}

model MediaFolder {
  id        String    @id @default(uuid())
  companyId String
  name      String
  parentId  String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   MediaFolder[] @relation("MediaFolderTree")
  media      ProductMedia[]

  @@index([companyId])
  @@index([parentId])
}

model ProductExportJob {
  id        String          @id @default(uuid())
  companyId String
  type      ExportType
  status    ExportJobStatus @default(PENDING)
  fileUrl   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

// ─── NEGOTIATION MODELS ────────────────────────────────────────────

model Negotiation {
  id                    String            @id @default(uuid())
  quoteId               String            @unique
  rfqId                 String
  buyerCompanyId        String
  sellerCompanyId       String
  status                NegotiationStatus @default(NEGOTIATION_STARTED)

  proposedPrice         Decimal?          @db.Decimal(14, 2)
  proposedMoq           Int?
  proposedLeadTimeDays  Int?
  proposedDeliveryTerms DeliveryTerms?
  proposedPaymentTerms  PaymentTerms?
  proposedDiscountPercent Decimal?        @db.Decimal(5, 2)
  proposedWarranty      String?
  proposedFreight       String?
  proposedValidityDate  DateTime?
  notes                 String?

  acceptedAt            DateTime?
  acceptedBy            String?
  rejectedAt            DateTime?
  rejectedBy            String?
  rejectionReason       String?
  cancelledAt           DateTime?
  cancelledBy           String?
  cancelReason          String?
  convertedAt           DateTime?
  expiredAt             DateTime?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  createdBy             String
  updatedBy             String?

  quote                 Quote             @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  rfq                   Rfq               @relation("NegotiationRfqs", fields: [rfqId], references: [id], onDelete: Restrict)
  buyerCompany          Company           @relation("BuyerNegotiations", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany         Company           @relation("SellerNegotiations", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  versions              NegotiationVersion[]
  events                NegotiationEvent[]
  purchaseOrder         PurchaseOrder?

  @@index([quoteId])
  @@index([rfqId])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
  @@index([status])
}

model NegotiationVersion {
  id                    String    @id @default(uuid())
  negotiationId         String
  version               Int
  proposedBy            String    // 'BUYER' | 'SELLER'
  proposedByUserId      String?

  proposedPrice         Decimal?  @db.Decimal(14, 2)
  proposedMoq           Int?
  proposedLeadTimeDays  Int?
  proposedDeliveryTerms String?
  proposedPaymentTerms  String?
  proposedDiscountPercent Decimal? @db.Decimal(5, 2)
  proposedWarranty      String?
  proposedFreight       String?
  proposedValidityDate  DateTime?
  notes                 String?

  changedFields         Json?
  metadata              Json?
  createdAt             DateTime  @default(now())

  negotiation           Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
  @@index([negotiationId, version])
}

model NegotiationEvent {
  id                    String              @id @default(uuid())
  negotiationId         String
  eventType             NegotiationEventType
  actorId               String
  actorRole             String?             // 'BUYER' | 'SELLER' | 'SYSTEM' | 'ADMIN'
  metadata              Json?
  createdAt             DateTime            @default(now())

  negotiation           Negotiation         @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
  @@index([negotiationId, eventType])
}

// ─── PURCHASE ORDER ENUMS ──────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  BUYER_CONFIRMED
  SELLER_PENDING
  SELLER_ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
  LOCKED
  CONVERTED_TO_ORDER
}

enum PoEventType {
  PO_GENERATED
  PO_CONFIRMED
  PO_SELLER_PENDING
  PO_SELLER_ACCEPTED
  PO_REJECTED
  PO_CANCELLED
  PO_EXPIRED
  PO_LOCKED
  PO_CONVERTED
  PO_REVISION_REQUESTED
  PO_REVISED
}

// ─── PURCHASE ORDER MODELS ─────────────────────────────────────────

model PurchaseOrder {
  id              String              @id @default(uuid())
  poNumber        String              @unique
  negotiationId   String              @unique
  negotiation     Negotiation         @relation(fields: [negotiationId], references: [id], onDelete: Restrict)
  quoteId         String
  rfqId           String
  buyerCompanyId  String
  sellerCompanyId String
  status          PurchaseOrderStatus @default(DRAFT)

  currency          String        @default("INR")
  subtotal          Decimal?      @db.Decimal(14, 2)
  taxAmount         Decimal?      @db.Decimal(14, 2)
  totalAmount       Decimal?      @db.Decimal(14, 2)
  discountAmount    Decimal?      @db.Decimal(14, 2)
  discountPercent   Decimal?      @db.Decimal(5, 2)
  deliveryTerms     DeliveryTerms?
  paymentTerms      PaymentTerms?
  leadTimeDays      Int?
  leadTimeDisplay   String?
  validityDate      DateTime?
  warranty          String?
  freight           String?
  packing           String?
  specialConditions String?
  commercialNotes   String?
  gstType           String?
  gstRate           Decimal?      @db.Decimal(5, 2)
  gstDetails        Json?

  draftCreatedAt     DateTime    @default(now())
  buyerConfirmedAt   DateTime?
  sellerPendingAt    DateTime?
  sellerAcceptedAt   DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  cancelledAt        DateTime?
  cancelReason       String?
  expiredAt          DateTime?
  lockedAt           DateTime?
  convertedAt        DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  createdBy         String
  updatedBy         String?

  buyerCompany      Company               @relation("BuyerPurchaseOrders", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany     Company               @relation("SellerPurchaseOrders", fields: [sellerCompanyId], references: [id], onDelete: Restrict)

  lineItems     PurchaseOrderLineItem[]
  attachments   PurchaseOrderAttachment[]
  versions      PurchaseOrderVersion[]
  events        PurchaseOrderEvent[]
        orders        Order[]               @relation("PoOrders")
        shipments     Shipment[]            @relation("PoShipments")

  @@index([negotiationId])
  @@index([quoteId])
  @@index([rfqId])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderLineItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  productName     String
  description     String?
  quantity        Int?
  unit            String?
  unitPrice       Decimal  @db.Decimal(14, 2)
  totalPrice      Decimal? @db.Decimal(14, 2)
  gstRate         Decimal? @db.Decimal(5, 2)
  gstAmount       Decimal? @db.Decimal(14, 2)
  deliveryTerms   String?
  leadTimeDays    Int?
  notes           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseOrderAttachment {
  id              String   @id @default(uuid())
  purchaseOrderId String
  type            String
  url             String
  originalName    String?
  mimeType        String?
  fileSize        Int?
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseOrderVersion {
  id              String   @id @default(uuid())
  purchaseOrderId String
  version         Int
  status          PurchaseOrderStatus
  data            Json?
  changedFields   Json?
  createdBy       String
  notes           String?
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([purchaseOrderId, version])
}

model PurchaseOrderEvent {
  id              String        @id @default(uuid())
  purchaseOrderId String
  eventType       PoEventType
  actorId         String
  actorRole       String?
  metadata        Json?
  createdAt       DateTime      @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([purchaseOrderId, eventType])
}

// ─── SHIPMENT & LOGISTICS ─────────────────────────────────────────

enum ShipmentStatus {
  PREPARING
  PACKED
  READY_FOR_PICKUP
  COURIER_ASSIGNED
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED
}

enum ShipmentType {
  STANDARD
  EXPRESS
  PARTIAL
  SPLIT
  INTERNATIONAL
  PICKUP
}

model CourierProvider {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  apiProvider  String?
  trackingUrl  String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shipments    Shipment[]

  @@index([isActive])
}

model Shipment {
  id                String        @id @default(uuid())
  shipmentNumber    String        @unique
  orderId           String
  purchaseOrderId   String?
  type              ShipmentType  @default(STANDARD)
  status            ShipmentStatus @default(PREPARING)
  statusChangedAt   DateTime      @default(now())
  statusChangedBy   String

  courierProviderId String?
  courierProvider   CourierProvider? @relation(fields: [courierProviderId], references: [id], onDelete: SetNull)
  trackingNumber    String?       @unique
  courierDetails    Json?

  weight            Decimal?      @db.Decimal(10, 2)
  weightUnit        String?       @default("kg")
  totalPackages     Int           @default(1)

  dispatchDate      DateTime?
  estimatedDeliveryDate DateTime?
  deliveredAt       DateTime?

  deliveryAddress   Json?
  pickupAddress     Json?
  specialInstructions String?
  buyerNotes        String?
  sellerNotes       String?

  buyerCompanyId    String
  sellerCompanyId   String
  createdBy         String
  updatedBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  order             Order         @relation("OrderShipments", fields: [orderId], references: [id], onDelete: Restrict)
  purchaseOrder     PurchaseOrder? @relation("PoShipments", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  buyerCompany      Company       @relation("ShipmentBuyer", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany     Company       @relation("ShipmentSeller", fields: [sellerCompanyId], references: [id], onDelete: Restrict)

  packages          ShipmentPackage[]
  timeline          ShipmentTimelineEvent[]
  documents         ShipmentDocument[]
  delivery          Delivery?

  @@index([orderId])
  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([courierProviderId])
  @@index([trackingNumber])
  @@index([createdAt])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
}

model ShipmentPackage {
  id          String   @id @default(uuid())
  shipmentId  String
  label       String?
  weight      Decimal? @db.Decimal(10, 2)
  weightUnit  String   @default("kg")
  length      Decimal? @db.Decimal(8, 2)
  width       Decimal? @db.Decimal(8, 2)
  height      Decimal? @db.Decimal(8, 2)
  contents    String?
  declaredValue Decimal? @db.Decimal(14, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model ShipmentTimelineEvent {
  id          String        @id @default(uuid())
  shipmentId  String
  fromStatus  ShipmentStatus?
  toStatus    ShipmentStatus
  changedBy   String
  changedByRole String?
  location    String?
  note        String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  shipment    Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([shipmentId, createdAt])
}

model ShipmentDocument {
  id          String   @id @default(uuid())
  shipmentId  String
  docType     String
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([shipmentId, docType])
}

// ─── DELIVERY & PROOF OF DELIVERY ────────────────────────────────

enum DeliveryStatus {
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_CONFIRMED
  DELIVERY_FAILED
  PARTIALLY_DELIVERED
  REJECTED
  RETURNED
  COMPLETED
}

model Delivery {
  id                String         @id @default(uuid())
  deliveryNumber    String         @unique
  shipmentId        String         @unique
  orderId           String
  status            DeliveryStatus @default(OUT_FOR_DELIVERY)
  statusChangedAt   DateTime       @default(now())
  statusChangedBy   String

  deliveredAt       DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?

  receiverName      String?
  receiverMobile    String?
  courierNotes      String?
  buyerNotes        String?
  rejectionReason   String?
  rejectionNote     String?

  buyerCompanyId    String
  sellerCompanyId   String
  createdBy         String
  updatedBy         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  shipment          Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  order             Order          @relation("OrderDeliveries", fields: [orderId], references: [id], onDelete: Restrict)
  buyerCompany      Company        @relation("DeliveryBuyer", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany     Company        @relation("DeliverySeller", fields: [sellerCompanyId], references: [id], onDelete: Restrict)

  proofOfDelivery   ProofOfDelivery?
  timeline          DeliveryTimelineEvent[]
  documents         DeliveryDocument[]

  @@index([shipmentId])
  @@index([orderId])
  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
  @@index([createdAt])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
}

model ProofOfDelivery {
  id                  String   @id @default(uuid())
  deliveryId          String   @unique
  receiverName        String?
  receiverMobile      String?
  otpVerified         Boolean  @default(false)
  digitalSignatureUrl String?
  photoUrls           Json?
  geoLatitude         Decimal? @db.Decimal(10, 7)
  geoLongitude        Decimal? @db.Decimal(10, 7)
  courierNotes        String?
  buyerNotes          String?
  deliveredAt         DateTime @default(now())
  confirmedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  delivery            Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model DeliveryTimelineEvent {
  id          String         @id @default(uuid())
  deliveryId  String
  fromStatus  DeliveryStatus?
  toStatus    DeliveryStatus
  changedBy   String
  changedByRole String?
  note        String?
  createdAt   DateTime       @default(now())

  delivery    Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([deliveryId, createdAt])
}

model DeliveryDocument {
  id          String   @id @default(uuid())
  deliveryId  String
  docType     String
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([deliveryId, docType])
}

// ─── Campaign Engine ─────────────────────────────────────────

enum CampaignType {
  SIGNUP
  MEMBERSHIP
  CASHBACK
  FESTIVAL
  REFERRAL
  SELLER
  BUYER
  CATEGORY
  PRODUCT
  ORDER
  COUPON
  LIMITED_TIME
  AI
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
  EXPIRED
}

enum CampaignTargetType {
  BUYER
  SELLER
  COMPANY
  MEMBERSHIP
  PRODUCT_CATEGORY
  PRODUCT
  STATE
  CITY
  INDUSTRY
  REVENUE_TIER
  GLOBAL_REGION
}

enum CampaignClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  FAILED
}

model Campaign {
  id              String         @id @default(uuid())
  name            String
  description     String?
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  priority        Int            @default(0)
  startDate       DateTime
  endDate         DateTime
  budget          Decimal        @db.Decimal(12, 2) @default(0)
  spentBudget     Decimal        @db.Decimal(12, 2) @default(0)
  remainingBudget  Decimal       @db.Decimal(12, 2) @default(0)
  maxRewards      Int            @default(0)
  dailyLimit      Int            @default(0)
  perUserLimit    Int            @default(0)
  perCompanyLimit Int            @default(0)
  maxClaims       Int            @default(0)
  currentClaims   Int            @default(0)
  rewardAmount    Decimal        @db.Decimal(10, 2) @default(0)
  rewardType      String         @default("FIXED_AMOUNT")
  eligibility     Json?
  targetAudience  Json?
  metadata        Json?
  companyId       String?
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  rules     CampaignRule[]
  targets   CampaignTarget[]
  claims    CampaignClaim[]
  analytics CampaignAnalytics[]

  @@index([type])
  @@index([status])
  @@index([startDate, endDate])
  @@index([priority])
  @@index([companyId])
  @@index([createdBy])
}

model CampaignRule {
  id               String   @id @default(uuid())
  campaignId       String
  priority         Int      @default(0)
  conditionField   String
  conditionOperator String
  conditionValue   Json
  actionType       String   // REWARD, DISCOUNT, BONUS, MULTIPLIER
  actionValue      Json
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, priority])
}

model CampaignTarget {
  id         String           @id @default(uuid())
  campaignId String
  targetType CampaignTargetType
  targetId   String
  isInclude  Boolean          @default(true)
  createdAt  DateTime         @default(now())

  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, targetType])
  @@index([targetType, targetId])
}

model CampaignClaim {
  id            String             @id @default(uuid())
  campaignId    String
  userId        String
  companyId     String?
  claimType     String             // REWARD, DISCOUNT, CASHBACK
  amount        Decimal            @db.Decimal(10, 2) @default(0)
  status        CampaignClaimStatus @default(PENDING)
  transactionId String?
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  claimedAt     DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  campaign      Campaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  @@index([campaignId])
  @@index([userId])
  @@index([companyId])
  @@index([campaignId, userId])
  @@index([status])
  @@index([transactionId])
  @@index([ipAddress])
  @@index([claimedAt])
}

model CampaignAnalytics {
  id              String   @id @default(uuid())
  campaignId      String
  date            DateTime
  claims          Int      @default(0)
  approved        Int      @default(0)
  rejected        Int      @default(0)
  paid            Int      @default(0)
  rewardAmount    Decimal  @db.Decimal(12, 2) @default(0)
  uniqueUsers     Int      @default(0)
  conversionCount Int      @default(0)
  conversionRate  Decimal  @db.Decimal(5, 2) @default(0)
  createdAt       DateTime @default(now())

  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

// ─── Enterprise Advertising Platform ────────────────────────────

enum AdType {
  SPONSORED_PRODUCT
  SPONSORED_COMPANY
  SPONSORED_CATEGORY
  HOMEPAGE_BANNER
  CATEGORY_BANNER
  SEARCH_KEYWORD_AD
  CITY_PROMOTION
  FEATURED_SELLER
  FEATURED_BRAND
}

enum AdStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
  REJECTED
  COMPLETED
}

enum AdPricingModel {
  CPC
  CPM
  FIXED
}

enum AdTargetType {
  COUNTRY
  STATE
  CITY
  CATEGORY
  PRODUCT
  KEYWORD
  INDUSTRY
}

model Advertisement {
  id            String         @id @default(uuid())
  companyId     String
  type          AdType
  status        AdStatus       @default(DRAFT)
  pricingModel  AdPricingModel
  title         String?
  description   String?
  imageUrl      String?
  targetUrl     String?
  dailyBudget   Decimal        @db.Decimal(12, 2) @default(0)
  totalBudget   Decimal        @db.Decimal(12, 2) @default(0)
  spentBudget   Decimal        @db.Decimal(12, 2) @default(0)
  cpc           Decimal?       @db.Decimal(10, 2)
  cpm           Decimal?       @db.Decimal(10, 2)
  fixedPrice    Decimal?       @db.Decimal(12, 2)
  startDate     DateTime
  endDate       DateTime
  autoPause     Boolean        @default(false)
  autoResume    Boolean        @default(false)
  autoStop      Boolean        @default(false)
  productId     String?
  categoryId    String?
  keyword       String?
  city          String?
  brandId       String?
  priority      Int            @default(0)
  impressions   Int            @default(0)
  clicks        Int            @default(0)
  metadata      Json?
  approvedBy    String?
  approvedAt    DateTime?
  rejectedReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  targets       AdTarget[]
  analytics     AdAnalytics[]

  @@index([companyId])
  @@index([status])
  @@index([type, status])
  @@index([startDate, endDate])
}

model AdTarget {
  id              String       @id @default(uuid())
  advertisementId String
  targetType      AdTargetType
  targetValue     String
  createdAt       DateTime     @default(now())

  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)

  @@index([advertisementId])
  @@index([targetType, targetValue])
}

model AdAnalytics {
  id              String       @id @default(uuid())
  advertisementId String
  date            DateTime
  impressions     Int          @default(0)
  clicks          Int          @default(0)
  spend           Decimal      @db.Decimal(12, 2) @default(0)
  conversions     Int          @default(0)
  conversionValue Decimal?     @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)

  @@unique([advertisementId, date])
  @@index([advertisementId])
  @@index([date])
}

// ─── Enterprise CRM & Lead Management ──────────────────────────

enum CrmLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTATION_SENT
  NEGOTIATION
  WON
  LOST
  DORMANT
}

enum CrmPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CrmLeadSource {
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  COLD_CALL
  EVENT
  PARTNER
  DIRECT
  OTHER
}

enum CrmFollowUpStatus {
  PENDING
  COMPLETED
  OVERDUE
  ESCALATED
}

enum CrmTaskType {
  CALL
  MEETING
  REMINDER
  EMAIL
  WHATSAPP
  CUSTOM
}

enum CrmTaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model CrmLead {
  id               String       @id @default(uuid())
  companyId        String?
  name             String
  email            String?
  mobile           String?
  source           CrmLeadSource?
  status           CrmLeadStatus @default(NEW)
  stageId          String?
  priority         CrmPriority   @default(MEDIUM)
  ownerId          String?
  score            Int           @default(0)
  estimatedValue   Decimal?      @db.Decimal(12, 2)
  description      String?
  convertedAt      DateTime?
  convertedCompanyId String?
  lostReason       String?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company          Company?      @relation("CrmLeadCompany", fields: [companyId], references: [id], onDelete: SetNull)
  owner            User?         @relation("CrmLeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  stage            CrmPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  followUps        CrmFollowUp[]
  notes            CrmNote[]
  tasks            CrmTask[]
  timeline         CrmTimelineEvent[]

  @@index([companyId])
  @@index([ownerId])
  @@index([status])
  @@index([stageId])
  @@index([priority])
  @@index([createdAt])
}

model CrmFollowUp {
  id          String           @id @default(uuid())
  leadId      String
  title       String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  status      CrmFollowUpStatus @default(PENDING)
  reminderSent Boolean         @default(false)
  escalatedTo String?
  escalatedAt DateTime?
  assignedTo  String?
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  lead        CrmLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedTo])
}

model CrmNote {
  id          String      @id @default(uuid())
  leadId      String
  content     String
  isPinned    Boolean     @default(false)
  mentions    String[]
  attachments Json?
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lead        CrmLead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model CrmTask {
  id          String       @id @default(uuid())
  leadId      String
  type        CrmTaskType
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      CrmTaskStatus @default(PENDING)
  assignedTo  String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead        CrmLead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([dueDate])
  @@index([assignedTo])
  @@index([type])
}

model CrmTimelineEvent {
  id          String   @id @default(uuid())
  leadId      String
  type        String
  description String?
  metadata    Json?
  createdBy   String?
  createdAt   DateTime @default(now())

  lead        CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([leadId, createdAt])
  @@index([type])
}

model CrmPipelineStage {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  color     String?
  isDefault Boolean  @default(false)
  isWon     Boolean  @default(false)
  isLost    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads     CrmLead[]

  @@index([order])
}

// ──────────────────────────────────────────────
// Phase 16.5 — Enterprise Finance Engine
// ──────────────────────────────────────────────

enum CreditStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CreditApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

enum DebitNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

enum CollectionActionType {
  CALL
  EMAIL
  VISIT
  LETTER
  PAYMENT_PLAN
  ESCALATION
  LEGAL
}

model BuyerCredit {
  id              String       @id @default(uuid())
  companyId       String       @unique
  creditLimit     Decimal      @default(0) @db.Decimal(14, 2)
  availableCredit Decimal      @default(0) @db.Decimal(14, 2)
  usedCredit      Decimal      @default(0) @db.Decimal(14, 2)
  blockedCredit   Decimal      @default(0) @db.Decimal(14, 2)
  status          CreditStatus @default(ACTIVE)
  riskLevel       RiskLevel    @default(LOW)
  lastReviewedAt  DateTime?
  reviewedBy      String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company         Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  history         CreditHistory[]
  approvals       CreditApproval[]

  @@index([companyId])
  @@index([status])
  @@index([riskLevel])
}

model CreditHistory {
  id          String       @id @default(uuid())
  buyerCreditId String
  changeType  String       // LIMIT_CHANGED, CREDIT_USED, CREDIT_RELEASED, BLOCKED, SUSPENDED, RESTORED
  amount      Decimal?     @db.Decimal(14, 2)
  balanceAfter Decimal?    @db.Decimal(14, 2)
  reason      String?
  changedBy   String
  createdAt   DateTime     @default(now())

  buyerCredit BuyerCredit  @relation(fields: [buyerCreditId], references: [id], onDelete: Cascade)

  @@index([buyerCreditId])
  @@index([createdAt])
}

model CreditApproval {
  id              String               @id @default(uuid())
  buyerCreditId   String
  requestType     String               // LIMIT_INCREASE, CREDIT_EXTENSION, SUSPENSION_OVERRIDE
  status          CreditApprovalStatus @default(PENDING)
  requestedLimit  Decimal?             @db.Decimal(14, 2)
  currentLimit    Decimal?             @db.Decimal(14, 2)
  reason          String?
  requestedBy     String
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  buyerCredit     BuyerCredit          @relation(fields: [buyerCreditId], references: [id], onDelete: Cascade)

  @@index([buyerCreditId])
  @@index([status])
}

model CreditNote {
  id              String           @id @default(uuid())
  creditNoteNumber String          @unique
  invoiceId       String
  companyId       String
  reason          String           // RETURN, DISCOUNT, ADJUSTMENT, CANCELLATION, OTHER
  subtotal        Decimal          @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal?         @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal          @default(0) @db.Decimal(12, 2)
  currency        String           @default("INR")
  gstNumber       String?
  gstType         TaxType?
  cgstAmount      Decimal?         @db.Decimal(12, 2)
  sgstAmount      Decimal?         @db.Decimal(12, 2)
  igstAmount      Decimal?         @db.Decimal(12, 2)
  hsnSacCode      String?
  status          CreditNoteStatus @default(DRAFT)
  issuedAt        DateTime?
  appliedAt       DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items           CreditNoteItem[]

  @@index([creditNoteNumber])
  @@index([invoiceId])
  @@index([companyId])
  @@index([status])
}

model CreditNoteItem {
  id          String      @id @default(uuid())
  creditNoteId String
  description String
  hsnSacCode  String?
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(12, 2)
  amount      Decimal     @db.Decimal(12, 2)
  sortOrder   Int         @default(0)

  creditNote  CreditNote  @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model DebitNote {
  id             String          @id @default(uuid())
  debitNoteNumber String         @unique
  invoiceId      String
  companyId      String
  reason         String          // ADDITIONAL_CHARGE, PENALTY, INTEREST, SHORTAGE, OTHER
  subtotal       Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal?        @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal         @default(0) @db.Decimal(12, 2)
  currency       String          @default("INR")
  gstNumber      String?
  gstType        TaxType?
  cgstAmount     Decimal?        @db.Decimal(12, 2)
  sgstAmount     Decimal?        @db.Decimal(12, 2)
  igstAmount     Decimal?        @db.Decimal(12, 2)
  hsnSacCode     String?
  status         DebitNoteStatus @default(DRAFT)
  issuedAt       DateTime?
  appliedAt      DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  items          DebitNoteItem[]

  @@index([debitNoteNumber])
  @@index([invoiceId])
  @@index([companyId])
  @@index([status])
}

model DebitNoteItem {
  id         String     @id @default(uuid())
  debitNoteId String
  description String
  hsnSacCode String?
  quantity   Int        @default(1)
  unitPrice  Decimal    @db.Decimal(12, 2)
  amount     Decimal    @db.Decimal(12, 2)
  sortOrder  Int        @default(0)

  debitNote  DebitNote  @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@index([debitNoteId])
}

model CollectionNote {
  id          String   @id @default(uuid())
  companyId   String
  actionType  CollectionActionType
  content     String
  contactedPerson String?
  outcome     String?
  followUpAt  DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([createdAt])
}

model CollectionTimelineEvent {
  id          String   @id @default(uuid())
  companyId   String
  type        String   // PAYMENT_RECEIVED, REMINDER_SENT, NOTE_ADDED, PROMISE_TO_PAY, ESCALATED, DISPUTE
  description String?
  metadata    Json?
  createdBy   String?
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([companyId, createdAt])
}

// ──────────────────────────────────────────────
// Phase 16.6A — AI Product Intelligence
// ──────────────────────────────────────────────

enum AiJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiJobType {
  DESCRIPTION_GENERATION
  SEO_GENERATION
  TRANSLATION
  SPEC_SUGGESTION
  IMAGE_SUGGESTION
  QUALITY_SCORE
  DUPLICATE_DETECTION
  BULK_ENHANCEMENT
}

model ProductTranslation {
  id               String   @id @default(uuid())
  productId        String
  locale           String
  name             String
  shortDescription String?
  description      String?
  isPrimary        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
  @@index([locale])
}

model CatalogQualityScore {
  id                  String   @id @default(uuid())
  productId           String   @unique
  total               Int      @default(0)
  titleQuality        Int      @default(0)
  descriptionQuality  Int      @default(0)
  imageQuality        Int      @default(0)
  specificationQuality Int     @default(0)
  seoQuality          Int      @default(0)
  categoryQuality     Int      @default(0)
  brandQuality        Int      @default(0)
  attributeQuality    Int      @default(0)
  completeness        Int      @default(0)
  recommendations     Json?
  lastCalculatedAt    DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([total])
}

model ProductAiCache {
  id          String     @id @default(uuid())
  productId   String
  cacheType   AiJobType
  prompt      String?
  response    Json?
  model       String?
  accepted    Boolean?
  createdAt   DateTime   @default(now())

  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, cacheType])
  @@index([createdAt])
}

model AiJob {
  id          String       @id @default(uuid())
  productId   String?
  companyId   String?
  jobType     AiJobType
  status      AiJobStatus  @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product     Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([jobType])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Phase 16.6C.1 — Enterprise AI Gateway & Provider Registry
// ──────────────────────────────────────────────

enum AiProviderStatus {
  ACTIVE
  DEGRADED
  DOWN
  DISABLED
}

enum TaskType {
  PRODUCT_DESCRIPTION
  SEO_GENERATION
  TRANSLATION
  SPEC_SUGGESTION
  IMAGE_SUGGESTION
  QUALITY_SCORING
  DUPLICATE_DETECTION
  OCR
  FAST_SUGGESTION
  LIVE_SEARCH
  WEBSITE_IMPORT
  RFQ_ANALYSIS
  QUOTE_ANALYSIS
  NEGOTIATION
  CRM_ANALYSIS
  FINANCE_ANALYSIS
  SEARCH_ANALYSIS
  ADMIN_INTELLIGENCE
  GENERAL_CHAT
}

enum AiCreditPeriod {
  MONTHLY
  LIFETIME
  PER_BUSINESS
}

model AiProvider {
  id              String             @id @default(uuid())
  name            String             @unique
  displayName     String
  providerType    String             // e.g. "openrouter", "gemini", "groq", "tavily", "firecrawl", "openai", "anthropic"
  enabled         Boolean            @default(false)
  priority        Int                @default(0)
  baseUrl         String?
  supportedModels Json               // JSON array of model names/objects
  supportedTasks  TaskType[]         // which task types this provider can handle
  timeoutMs       Int                @default(30000)
  retryCount      Int                @default(3)
  retryDelayMs    Int                @default(1000)
  rateLimitRpm    Int                @default(60)
  rateLimitTpm    Int                @default(100000)
  costPer1kInput  Float              @default(0)
  costPer1kOutput Float              @default(0)
  healthStatus    AiProviderStatus   @default(DISABLED)
  lastHealthCheckAt DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  failureCount    Int                @default(0)
  circuitOpen     Boolean            @default(false)
  circuitOpenUntil DateTime?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([enabled, priority])
  @@index([providerType])
}

model AiPrompt {
  id              String   @id @default(uuid())
  taskType        TaskType
  version         Int      @default(1)
  name            String
  description     String?
  systemPrompt    String
  userPrompt      String?
  variables       Json?    // JSON array of variable names expected in the prompt
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2048)
  providerOverride String? // optional: force a specific provider
  modelOverride   String?  // optional: force a specific model
  isActive        Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([taskType, version])
  @@index([taskType, isActive])
  @@index([name])
}

model AiUsage {
  id              String   @id @default(uuid())
  companyId       String
  userId          String?
  taskType        TaskType
  providerId      String?
  providerName    String?
  modelName       String?
  promptVersion   Int?
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  latencyMs       Int      @default(0)
  estimatedCost   Float    @default(0)
  cacheHit        Boolean  @default(false)
  queueTimeMs     Int      @default(0)
  success         Boolean  @default(true)
  errorMessage    String?
  idempotencyKey  String?  @unique
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([taskType, createdAt])
  @@index([providerId, createdAt])
  @@index([createdAt])
}

model AiCreditUsage {
  id          String   @id @default(uuid())
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  used        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, periodStart])
  @@index([companyId])
}
