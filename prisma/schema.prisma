// Migration command sequence:
//   1. pnpm db:generate    — generate Prisma client
//   2. pnpm db:migrate     — run prisma migrate dev
//   3. pnpm db:seed        — ts-node prisma/seed.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

