model User {
  id           String    @id @default(uuid())
  email        String    @unique
  mobile       String?
  panNumber    String?   @unique
  passwordHash String
  name         String
  role         Role      @default(VIEWER)
  status       String    @default("active")
  permissions  String[]  @default([])
  isActive     Boolean   @default(true)
  emailVerifiedAt DateTime?
  mobileVerifiedAt DateTime?
  verificationLevel VerificationLevel @default(LEVEL_0)
  deletedAt    DateTime?
  loginAttempts Int      @default(0)
  lockedUntil  DateTime?
  rmCode       String?  @unique
  meCode       String?  @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions                    Session[]
  auditLogs                   AuditLog[]
  organizationMembers         OrganizationMember[]
  organizationInvitationsSent OrganizationInvitation[] @relation("InvitationsSent")
  ownedCompanies              CompanyOwner[]
  companyVerifications        CompanyVerification[]  @relation("CompanyVerifications")
  verificationReviews         CompanyVerification[]  @relation("VerificationReviews")
  rmAttributions              CodeAttribution[]      @relation("RMAttributions")
  meAttributions              CodeAttribution[]      @relation("MEAttributions")
  managedCompanies            Company[]              @relation("RMManagedCompanies")
  rmCertificationReviews      CompanyCertification[] @relation("CertificationReviews")
  rfqsCreated                 Rfq[]                   @relation("RfqCreators")
  quotesSubmitted             Quote[]                 @relation("QuoteCreators")
  userVerifications           UserVerification[]      @relation("UserVerificationUser")
  userVerificationSubmissions UserVerification[]      @relation("UserVerificationSubmitter")
  userVerificationReviews     UserVerification[]      @relation("UserVerificationReviews")
  reputationEvents            ReputationEvent[]

  @@index([status])
  chatParticipants            ConversationParticipant[]
  notifications               Notification[]
  notificationPreferences     NotificationPreference[]
  verifiedPaymentProofs       ManualPaymentProof[]
   disputeMessages             DisputeMessage[]
   productApprovals            ProductApproval[]
   reportedMessages            ReportedMessage[]   @relation("ReportedBy")
    reviewedReports             ReportedMessage[]   @relation("ReviewedBy")
    crmLeads                    CrmLead[]           @relation("CrmLeadOwner")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  deviceInfo   String?
  isActive     Boolean  @default(true)
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([isActive])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  website     String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?

  members     OrganizationMember[]
  invitations OrganizationInvitation[]
  companies   Company[]

  @@index([slug])
  @@index([deletedAt])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           OrgMemberRole @default(MEMBER)
  invitedBy      String?
  joinedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id             String           @id @default(uuid())
  organizationId String
  email          String
  role           OrgMemberRole    @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User             @relation("InvitationsSent", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

model Category {
  id            String     @id @default(uuid())
  parentId      String?
  name          String
  slug          String     @unique
  description   String?
  icon          String?
  image         String?
  seoTitle      String?
  seoDescription String?
  isActive      Boolean    @default(true)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  parent        Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[] @relation("CategoryTree")
  companies     CompanyCategory[]
  products          Product[]
  productMasters    ProductMaster[]
  serviceMasters    ServiceMaster[]
  productDrafts     ProductDraft[]
  attributeTemplates AttributeTemplate[]
  templates         CategoryTemplate[]
  productLocationIndexes ProductLocationIndex[]
  rfqProductItems   RfqProductItem[]
  rfqs              Rfq[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
}

model Industry {
