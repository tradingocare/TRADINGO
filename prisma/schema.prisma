// ============================================================================
// GOCASH (GoCash) Rewards & Wallet Module
// ============================================================================

model GOCASH_Wallet {
  id                 String      @id @default(uuid())
  userId             String      @unique
  companyId         String?    // Optional for buyer wallets
  type              GOCASHWalletType
  currentBalance    Decimal    @default(0) @db.Decimal(10, 2)
  availableBalance   Decimal    @default(0) @db.Decimal(10, 2)
  pendingBalance     Decimal    @default(0) @db.Decimal(10, 2)
  lockedBalance      Decimal    @default(0) @db.Decimal(10, 2)
  expiredBalance     Decimal    @default(0) @db.Decimal(10, 2)
  lifetimeEarned     Decimal    @default(0) @db.Decimal(10, 2)
  lifetimeRedeemed   Decimal    @default(0) @db.Decimal(10, 2)
  lifetimeExpired    Decimal    @default(0) @db.Decimal(10, 2)
  phoneNumber       String?
  kycVerified        Boolean    @default(false)
  status            GOCASHWalletStatus @default(ACTIVE)
  lockedUntil       DateTime?
  createdAt         DateTime   @default(now())
  
  // Internal relations
  transactions       GOCASH_Transaction[]
  redemptions       GOCASH_Redemption[]
  
  // Indexes
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model GOCASH_Transaction {
  id                 String      @id @default(uuid())
  walletId           String
  direction          GOCASHLedgerDirection
  status             GOCASHLedgerStatus @default(SUCCESS)
  type              GOCASHTransactionType
  amount            Decimal    @db.Decimal(10, 2)
  balanceBefore      Decimal    @db.Decimal(10, 2)
  balanceAfter       Decimal    @db.Decimal(10, 2)
  currency           String     @default("GOCASH")
  reference          String?    // external reference (e.g., invoice ID)
  referenceType     String?    // module/entity type
  referenceId       String?    // ID of related entity
  sourceType        String?    // sub-type within module
  sourceSystem      String?    // TRADGO, AUTH, etc.
  idempotencyKey     String?   @unique
  reason            String
  notes             String?
  actorId           String      // Who initiated the transaction
  actorType         String      // USER, ADMIN, SYSTEM
  approvedBy        String?    // User ID who approved if needed
  approvedAt        DateTime?
  createdAt         DateTime   @default(now())
  
  // Internal relations
  wallet             GOCASH_Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([walletId])
  @@index([createdAt])
  @@index([type])
  @@index([direction])
  @@index([status])
  @@index([idempotencyKey])
  @@index([referenceId])
  @@index([walletId, createdAt])
}

model RewardCampaign {
  id                 String      @id @default(uuid())
  name               String
  description        String?
  type               GOCASH_CampaignType
  startDate          DateTime
  endDate            DateTime
  budget             Decimal    @db.Decimal(10, 2) @default(0)
  remainingBudget     Decimal    @db.Decimal(10, 2)
  requirement        String?    // Eligibility criteria
  rewardAmount       Decimal    @db.Decimal(10, 2)
  rewardType         String      // FIXED_AMOUNT, PERCENTAGE, SPECIFIC_ITEM
  maxClaims           Int        @default(0) // 0 means unlimited
  claimedCount        Int        @default(0)
  status             GOCASH_CampaignStatus @default(ACTIVE)
  companyId          String?
  createdBy          String
  
  // Plain FK references — no Prisma relations (avoids modifying locked User/Company models)
  
  // Indexes
  @@index([type])
  @@index([status])
  @@index([endDate])
  @@index([companyId])
}

model ReferralProgram {
  id                 String      @id @default(uuid())
  companyId          String
  name               String
  description        String?
  referralCode       String     @unique
  rewardAmount       Decimal    @db.Decimal(10, 2) @default(0)
  commissionRate     Decimal    @db.Decimal(5, 2) @default(0) // for seller referrals
  status             GOCASH_ReferralStatus @default(ACTIVE)
  maxReferrals       Int        @default(0) // 0 means unlimited
  usedCount          Int        @default(0)
  createdBy          String
  
  // Plain FK references — no Prisma relations (avoids modifying locked User/Company models)
  
  // Indexes
  @@index([companyId])
  @@index([referralCode])
  @@index([status])
}

// ============================================================================
// Referral Engine Models
// ============================================================================

model ReferralCode {
  id                 String             @id @default(uuid())
  code               String             @unique
  userId             String
  companyId          String?
  type               ReferralCodeType
  status             ReferralCodeStatus @default(ACTIVE)
  rewardAmount       Decimal?           @db.Decimal(10, 2)
  rewardType         String?            // FIXED, PERCENTAGE, TIER
  maxUsage           Int                @default(0) // 0 = unlimited
  currentUsage       Int                @default(0)
  expiresAt          DateTime?
  metadata           Json?
  createdBy          String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Internal relations
  usages             ReferralUsage[]

  // Indexes
  @@index([userId])
  @@index([code])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
}

model ReferralUsage {
  id                 String              @id @default(uuid())
  codeId             String
  referrerUserId     String
  refereeUserId      String?
  refereeEmail       String
  status             ReferralUsageStatus @default(PENDING)
  source             String?             // SIGNUP, CHECKOUT, CAMPAIGN, MANUAL
  ipAddress          String?
  userAgent          String?
  deviceId           String?
  metadata           Json?
  referredAt         DateTime            @default(now())
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Internal relations
  code               ReferralCode       @relation(fields: [codeId], references: [id], onDelete: Restrict)
  rewards            ReferralReward[]

  // Indexes
  @@index([codeId])
  @@index([referrerUserId])
  @@index([refereeEmail])
  @@index([status])
  @@index([ipAddress])
  @@index([deviceId])
  @@index([referredAt])
}

model ReferralReward {
  id                 String              @id @default(uuid())
  usageId            String
  referrerUserId     String
  refereeUserId      String?
  amount             Decimal             @db.Decimal(10, 2)
  type               String              // REFERRER, REFEREE
  status             ReferralRewardStatus @default(PENDING)
  transactionId      String?             // links to GOCASH_Transaction
  paidAt             DateTime?
  createdAt          DateTime            @default(now())

  // Internal relations
  usage              ReferralUsage       @relation(fields: [usageId], references: [id], onDelete: Restrict)

  // Indexes
  @@index([usageId])
  @@index([referrerUserId])
  @@index([status])
  @@index([transactionId])
}

model ReferralAudit {
  id                 String      @id @default(uuid())
  usageId            String?
  action             String      // CREATED, APPLIED, REWARDED, FAILED, REJECTED, BLACKLISTED
  details            String?
  ipAddress          String?
  actorId            String?
  metadata           Json?
  createdAt          DateTime    @default(now())

  // Indexes
  @@index([usageId])
  @@index([action])
  @@index([actorId])
  @@index([createdAt])
}

model ReferralRule {
  id                 String      @id @default(uuid())
  name               String
  description        String?
  type               String      // SIGNUP, MEMBERSHIP, PURCHASE, CAMPAIGN
  referrerReward     Decimal     @db.Decimal(10, 2)
  refereeReward      Decimal?    @db.Decimal(10, 2)
  rewardType         String      // FIXED, PERCENTAGE
  minAmount          Decimal?    @db.Decimal(10, 2)
  maxAmount          Decimal?    @db.Decimal(10, 2)
  conditions         Json?       // Eligibility conditions
  status             GOCASH_ReferralStatus @default(ACTIVE)
  startDate          DateTime?
  endDate            DateTime?
  createdBy          String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Indexes
  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model ReferralBlacklist {
  id                 String                @id @default(uuid())
  type               ReferralBlacklistType
  value              String
  reason             String?
  createdBy          String
  expiresAt          DateTime?
  createdAt          DateTime              @default(now())

  // Indexes
  @@index([type])
  @@index([value])
  @@index([expiresAt])
}

model GOCASH_Redemption {
  id                 String      @id @default(uuid())
  walletId           String
  amount             Decimal    @db.Decimal(10, 2)
  redemptionType     GOCASH_RedemptionType
  status             GOCASH_RedemptionStatus @default(PENDING)
  reference          String?    // Invoice/ID reference
  redeemedAt         DateTime?   // When redeemed (if approved)
  approvedAt         DateTime?   // When approved
  rejectedAt         DateTime?   // When rejected
  rejectionReason     String?    // If rejected
  approvedBy         String?    // Admin user ID
  createdAt          DateTime   @default(now())
  
  // Internal relations
  wallet             GOCASH_Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

