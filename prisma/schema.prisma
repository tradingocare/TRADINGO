  NEFT
  RTGS
  BANK_TRANSFER
}

model Escrow {
  id              String        @id @default(uuid())
  orderId         String        @unique
  buyerCompanyId  String
  sellerCompanyId String
  amount          Int
  goCashAmount    Int           @default(0)
  netAmount       Int
  status          EscrowStatus  @default(PENDING)
  heldAt          DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?
  disputedAt      DateTime?
  frozenAt        DateTime?
  disputedAmount  Int?
  autoReleaseAt   DateTime?
  manualReviewAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  buyerCompany    Company       @relation("EscrowBuyer", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany   Company       @relation("EscrowSeller", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  events          EscrowEvent[]
  settlements     Settlement[]
  disputes        Dispute[]

  @@index([orderId])
  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
}

model EscrowEvent {
  id          String          @id @default(uuid())
  escrowId    String
  type        EscrowEventType
  metadata    Json?
  createdById String
  createdAt   DateTime        @default(now())

  escrow      Escrow          @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([createdAt])
}

model Settlement {
  id              String            @id @default(uuid())
  escrowId        String
  amount          Int
  status          SettlementStatus  @default(PENDING)
  processedAt     DateTime?
  failedAt        DateTime?
  failedReason    String?
  retryCount      Int               @default(0)
  lastRetryAt     DateTime?
  settledAt       DateTime?
  createdById     String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  escrow          Escrow            @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  events          SettlementEvent[]

  @@index([escrowId])
  @@index([status])
}

model SettlementEvent {
  id            String              @id @default(uuid())
  settlementId  String
  type          SettlementEventType
  metadata      Json?
  createdById   String
  createdAt     DateTime            @default(now())

  settlement    Settlement          @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([createdAt])
}

model ManualPaymentProof {
  id                  String                            @id @default(uuid())
  paymentId           String                            @unique
  utrNumber           String?
  transactionScreenshot String?
  transactionDate     DateTime?
  bankName            String?
  paymentMethod       ManualPaymentMethod
  amount              Int
  verifiedById        String?
  verifiedAt          DateTime?
  verificationStatus  ManualPaymentVerificationStatus    @default(PENDING)
  remarks             String?
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt

  companyId           String
  payment             Payment                           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  company             Company                           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  verifiedBy          User?                             @relation(fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([companyId])
  @@index([verificationStatus])
}

enum DisputeType {
  PRODUCT
  SERVICE
  PAYMENT
  LOGISTICS
  OTHER
}

enum DisputeReason {
  QUALITY_ISSUE
  QUANTITY_ISSUE
  WRONG_PRODUCT
  LATE_DELIVERY
  PAYMENT_ISSUE
  SERVICE_ISSUE
  LOGISTICS_ISSUE
  DAMAGED_PRODUCT
  MISSING_ITEMS
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  EVIDENCE_PENDING
  NEGOTIATION
  ESCALATED
  ADMIN_ARBITRATION
  PARTIALLY_RESOLVED
  RESOLVED
  REFUNDED
  REJECTED
  CANCELLED
  EXPIRED
  APPEALED
}

enum ResolutionType {
  FULL_REFUND
  PARTIAL_REFUND
  REPLACEMENT
  PRICE_ADJUSTMENT
  SERVICE_REWORK
  NO_ACTION
}

model Dispute {
  id                String        @id @default(uuid())
  disputeNumber     String        @unique
  orderId           String
  escrowId          String?
  raisedByCompanyId String
  assignedAdminId String? // admin handling arbitration
  assignedAt DateTime? // when admin assigned
  arbitrationDueAt DateTime? // SLA deadline
  assignmentReason String? // e.g., round robin
  againstCompanyId  String
  type              DisputeType
  reason            DisputeReason
  status            DisputeStatus @default(OPEN)
  description       String
  amount            Int?
  currency          String        @default("INR")
  timeLimit         DateTime?
  filedAt           DateTime      @default(now())
  underReviewAt     DateTime?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  rejectedAt        DateTime?
  refundedAt        DateTime?
  cancelledAt       DateTime?
  expiredAt         DateTime?
  appealedAt        DateTime?
  createdBy         String
  updatedBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  order           Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  escrow          Escrow?           @relation(fields: [escrowId], references: [id], onDelete: SetNull)
  raisedByCompany Company           @relation("DisputeRaisedBy", fields: [raisedByCompanyId], references: [id], onDelete: Restrict)
  againstCompany  Company           @relation("DisputeAgainst", fields: [againstCompanyId], references: [id], onDelete: Restrict)
  messages        DisputeMessage[]
  evidence        DisputeEvidence[]
  timeline        DisputeTimelineEvent[]
  resolution      DisputeResolution?
  appeal          DisputeAppeal?
  disputeProcessorExecutions DisputeProcessorExecution[]

  @@index([orderId])
  @@index([escrowId])
  @@index([raisedByCompanyId])
  @@index([againstCompanyId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedAdminId])
  @@index([assignedAt])
  @@index([arbitrationDueAt])
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  senderId    String
  content     String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([disputeId])
  @@index([createdAt])
}

model DisputeEvidence {
  id          String   @id @default(uuid())
  disputeId   String
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  uploadedBy  String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeTimelineEvent {
  id          String   @id @default(uuid())
  disputeId   String
  type        String
  description String?
  metadata    Json?
  createdBy   String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([createdAt])
}

model DisputeResolution {
  id              String         @id @default(uuid())
  disputeId       String         @unique
  resolutionType  ResolutionType
  description     String?
  refundAmount    Int?
  replacementInfo String?
  priceAdjustment Int?
  approvedBy      String
  approvedAt      DateTime       @default(now())
  executedAt      DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  dispute         Dispute        @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeProcessorExecution {
  id          String   @id @default(uuid())
  jobId       String   @unique
  disputeId   String
  type        String
  processedAt DateTime @default(now())
  dispute     Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([processedAt])
  @@unique([disputeId, type])
}

model DisputeAppeal {
  id              String        @id @default(uuid())
  disputeId       String        @unique
  reason          String
  supportingInfo  String?
  filedBy         String
  filedAt         DateTime      @default(now())
  status          String        @default("PENDING")
  reviewedBy      String?
  reviewedAt      DateTime?
  decision        String?
  decisionNotes   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  dispute         Dispute       @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

