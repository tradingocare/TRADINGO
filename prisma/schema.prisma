// Migration command sequence:
//   1. pnpm db:generate    — generate Prisma client
//   2. pnpm db:migrate     — run prisma migrate dev
//   3. pnpm db:seed        — ts-node prisma/seed.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  VIEWER
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum BusinessType {
  MANUFACTURER
  EXPORTER
  IMPORTER
  DISTRIBUTOR
  WHOLESALER
  RETAILER
  TRADER
  BROKER
  SERVICE_PROVIDER
  OEM
  CONTRACT_MANUFACTURER
}

enum GeographicReach {
  LOCAL
  DISTRICT
  STATE
  PAN_INDIA
  GLOBAL
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  VERIFIED
}

enum VerificationLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
  LEVEL_6
}

enum LocationType {
  HEAD_OFFICE
  BRANCH
  WAREHOUSE
  FACTORY
  PICKUP
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum OnboardingStep {
  ACCOUNT_CREATED
  BUSINESS_ADDED
  KYC_STARTED
  KYC_COMPLETED
  PRODUCTS_ADDED
  SUBSCRIPTION_ACTIVATED
}

enum CertificationType {
  MSME
  IEC
  FSSAI
  ISO
  BIS
  CE
  OTHERS
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum GalleryModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GoCashTransactionType {
  EARNED
  REDEEMED
  BONUS
  REFERRAL
  ADMIN_CREDIT
  ADMIN_DEBIT
  EXPIRED
}

enum GoCashRedemptionType {
  PLANS
  RFQ_PACKS
  FEATURED_LISTINGS
  SPONSORED_LISTINGS
  ORDERS
}

enum AnalyticsEventType {
  PROFILE_VIEW
  PRODUCT_VIEW
  RFQ_SUBMITTED
  ORDER_PLACED
  SEARCH_IMPRESSION
  SEARCH_CLICK
  QUOTE_SENT
  QUOTE_ACCEPTED
}

enum PlanType {
  TRADE_START
  TRADE_SMART
  TRADE_PLUS
  TRADE_PRO
  TRADE_PREMIUM
  TRADE_ELITE
  TRADBUY
}

enum RfqType {
  PRODUCT
  SERVICE
  BULK
  URGENT
}

enum RfqStatus {
  DRAFT
  ACTIVE
  MATCHED
  QUOTED
  NEGOTIATING
  ACCEPTED
  CONVERTED
  CLOSED
  EXPIRED
  CANCELLED
}

enum RfqVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum RfqUrgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RfqAttachmentType {
  IMAGE
  PDF
  VIDEO
  DOCUMENT
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  VIEWED
  NEGOTIATING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum QuoteEventType {
  QUOTE_CREATED
  QUOTE_VIEWED
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  QUOTE_EXPIRED
}

enum DeliveryTerms {
  EX_WORKS
  FOB
  CIF
  CFR
  CPT
  CIP
  DAP
  DDP
  FAS
  FCA
  OTHER
}

enum PaymentTerms {
  ADVANCE
  LC_AT_SIGHT
  LC_USANCE
  TT
  DD
  CHEQUE
  COD
  CREDIT_30
  CREDIT_60
  CREDIT_90
  SIGN_AGAINST_DOCUMENTS
  DOCUMENT_AGAINST_PAYMENT
  OTHER
}

enum MatchStatus {
  PENDING
  SENT
  VIEWED
  QUOTED
  DECLINED
  EXPIRED
}

enum CreditTransactionType {
  PURCHASE
  USED
  REFUNDED
  BONUS
  EXPIRED
  ADMIN_CREDIT
  ADMIN_DEBIT
}

enum RfqAnalyticsEventType {
  CREATED
  PUBLISHED
  MATCHED
  QUOTED
  ACCEPTED
  CONVERTED
  EXPIRED
}

enum SubscriptionAlertPeriod {
  DAY_30
  DAY_15
  DAY_7
  DAY_3
  DAY_1
}

enum DocumentType {
  PAN
  GST
  AADHAAR
  BUSINESS_REGISTRATION
  CANCELLED_CHEQUE
  BANK_VERIFICATION
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  RAW_MATERIAL
  MACHINERY
  EQUIPMENT
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum ClaimStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum VariantType {
  COLOR
  SIZE
  WEIGHT
  GRADE
  THICKNESS
  LENGTH
  WIDTH
  HEIGHT
  CAPACITY
  VOLTAGE
  POWER_RATING
  MATERIAL
  FINISH
  MODEL_NUMBER
  PACKAGING_TYPE
  DENSITY
  DIAMETER
  GSM
  MICRON
  CUSTOM
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(VIEWER)
  permissions  String[]  @default([])
  isActive     Boolean   @default(true)
  emailVerifiedAt DateTime?
  deletedAt    DateTime?
  loginAttempts Int      @default(0)
  lockedUntil  DateTime?
  rmCode       String?  @unique
  meCode       String?  @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions                    Session[]
  auditLogs                   AuditLog[]
  organizationMembers         OrganizationMember[]
  organizationInvitationsSent OrganizationInvitation[] @relation("InvitationsSent")
  ownedCompanies              CompanyOwner[]
  companyVerifications        CompanyVerification[]  @relation("CompanyVerifications")
  verificationReviews         CompanyVerification[]  @relation("VerificationReviews")
  rmAttributions              CodeAttribution[]      @relation("RMAttributions")
  meAttributions              CodeAttribution[]      @relation("MEAttributions")
  managedCompanies            Company[]              @relation("RMManagedCompanies")
  rmCertificationReviews      CompanyCertification[] @relation("CertificationReviews")
  rfqsCreated                 Rfq[]                   @relation("RfqCreators")
  quotesSubmitted             Quote[]                 @relation("QuoteCreators")
  chatParticipants            ConversationParticipant[]
  notifications               Notification[]
  notificationPreferences     NotificationPreference[]
  verifiedPaymentProofs       ManualPaymentProof[]
  disputeMessages             DisputeMessage[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  website     String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?

  members     OrganizationMember[]
  invitations OrganizationInvitation[]
  companies   Company[]

  @@index([slug])
  @@index([deletedAt])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           OrgMemberRole @default(MEMBER)
  invitedBy      String?
  joinedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id             String           @id @default(uuid())
  organizationId String
  email          String
  role           OrgMemberRole    @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User             @relation("InvitationsSent", fields: [invitedBy], references: [id])

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

model Category {
  id            String     @id @default(uuid())
  parentId      String?
  name          String
  slug          String     @unique
  description   String?
  icon          String?
  image         String?
  seoTitle      String?
  seoDescription String?
  isActive      Boolean    @default(true)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  parent        Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryTree")
  companies     CompanyCategory[]
  products          Product[]
  productMasters    ProductMaster[]
  serviceMasters    ServiceMaster[]
  productDrafts     ProductDraft[]
  attributeTemplates AttributeTemplate[]
  templates         CategoryTemplate[]
  productLocationIndexes ProductLocationIndex[]
  rfqProductItems   RfqProductItem[]
  rfqs              Rfq[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
}

model Industry {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies   CompanyIndustry[]
  products    Product[]
  rfqs        Rfq[]

  @@index([slug])
}

model Company {
  id               String           @id @default(uuid())
  organizationId   String?
  name             String
  slug             String           @unique
  logo             String?
  banner           String?
  description      String?
  businessType     BusinessType?
  establishedYear  Int?
  employeeCount    Int?
  gstNumber        String?
  panNumber        String?
  website          String?
  email            String?
  mobile           String?
  trustScore       Int              @default(0)
  verificationLevel VerificationLevel @default(LEVEL_0)
  geographicReach  GeographicReach?
  status           CompanyStatus    @default(ACTIVE)
  totalProducts    Int              @default(0)
  responseRate     Float            @default(0)
  vendorCode       String?          @unique
  onboardedByCode  String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionPlan PlanType?
  subscriptionActivatedAt DateTime?
  subscriptionExpiresAt DateTime?
  subscriptionGraceStart DateTime?
  goCashBalance      Int              @default(0)
  certifications   Json?
  gallery          Json?
  maxSampleProducts Int             @default(5)
  profileCompletionPercentage Int   @default(0)
  onboardingStatus OnboardingStep?
  onboardingStartedAt DateTime?
  onboardingCompletedAt DateTime?
  assignedRmId     String?
  assignedAt       DateTime?
  referralRewardedAt DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  createdBy        String
  updatedBy        String?

  organization     Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  owners           CompanyOwner[]
  locations        CompanyLocation[]
  categories       CompanyCategory[]
  industries       CompanyIndustry[]
  verifications    CompanyVerification[]
  tradTrustScores  TradTrustScore[]
  products         Product[]
  productLocationIndexes ProductLocationIndex[]
  certificationDocs CompanyCertification[]
  galleryImages    CompanyGalleryImage[]
  goCashTransactions GoCashTransaction[]
  analyticsEvents  SellerAnalyticsEvent[]
  onboardingLogs   CompanyOnboardingLog[]
  subscriptionEvents SubscriptionEvent[]
  assignedRm       User?                @relation("RMManagedCompanies", fields: [assignedRmId], references: [id], onDelete: SetNull)

  rfqsCreated      Rfq[]                @relation("BuyerRfqs")
  rfqMatches       RfqVendorMatch[]     @relation("MatchedSellers")
  quotesSubmitted  Quote[]              @relation("SellerQuotes")
  rfqCreditLedgers RfqCreditLedger[]
  rfqCreditPacks   RfqCreditPack[]
  rfqAnalytics     RfqAnalytics?
  rfqAnalyticsEvents RfqAnalyticsEvent[]
  chatParticipants   ConversationParticipant[]
  buyerOrders        Order[]              @relation("OrderBuyer")
  sellerOrders       Order[]              @relation("OrderSeller")
  payments           Payment[]
  invoices           Invoice[]
  payouts            Payout[]
  fileScans          FileScan[]
  escrowsAsBuyer     Escrow[]             @relation("EscrowBuyer")
  escrowsAsSeller    Escrow[]             @relation("EscrowSeller")
  manualPaymentProofs ManualPaymentProof[]
  disputesRaised     Dispute[]            @relation("DisputeRaisedBy")
  disputesAgainst    Dispute[]            @relation("DisputeAgainst")
  notifications      Notification[]
  notificationPreferences NotificationPreference[]
  productDrafts      ProductDraft[]
  productClaims      ProductClaim[]
  reviews            ProductReview[]
  qa                 ProductQa[]

  @@index([slug])
  @@index([organizationId])
  @@index([businessType])
  @@index([trustScore])
  @@index([vendorCode])
  @@index([assignedRmId])
  @@index([deletedAt])
}

model CompanyOwner {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model CompanyLocation {
  id           String       @id @default(uuid())
  companyId    String
  type         LocationType @default(HEAD_OFFICE)
  addressLine1 String
  addressLine2 String?
  city         String
  district     String?
  state        String
  country      String       @default("India")
  pincode      String?
  latitude     Float?
  longitude    Float?
  isPrimary    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([city])
  @@index([state])
}

model CompanyCategory {
  companyId  String
  categoryId String

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([companyId, categoryId])
  @@index([companyId])
  @@index([categoryId])
}

model CompanyIndustry {
  companyId  String
  industryId String

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([companyId, industryId])
  @@index([companyId])
  @@index([industryId])
}

model CompanyVerification {
  id          String             @id @default(uuid())
  companyId   String
  level       VerificationLevel
  status      VerificationStatus @default(PENDING)
  submittedBy String
  reviewedBy  String?
  reviewedAt  DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submitter   User               @relation("CompanyVerifications", fields: [submittedBy], references: [id])
  reviewer    User?              @relation("VerificationReviews", fields: [reviewedBy], references: [id])
  documents   CompanyVerificationDocument[]

  @@index([companyId])
  @@index([status])
}

model CompanyVerificationDocument {
  id             String         @id @default(uuid())
  verificationId String
  documentType   DocumentType
  documentUrl    String
  status         VerificationStatus @default(PENDING)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  verification   CompanyVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([documentType])
}

model TradTrustScore {
  id          String   @id @default(uuid())
  companyId   String
  score       Int
  factors     Json
  calculatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([score])
}

model CompanyOnboardingLog {
  id        String         @id @default(uuid())
  companyId String
  step      OnboardingStep
  completed Boolean        @default(true)
  createdAt DateTime       @default(now())

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, step])
}

model CompanyCertification {
  id                  String              @id @default(uuid())
  companyId           String
  type                CertificationType
  documentUrl         String
  documentNumber      String?
  issuedBy            String?
  issuedAt            DateTime?
  expiresAt           DateTime?
  status              CertificationStatus  @default(PENDING)
  reviewedBy          String?
  reviewedAt          DateTime?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewer            User?                @relation("CertificationReviews", fields: [reviewedBy], references: [id])

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
}

model CompanyGalleryImage {
  id          String                 @id @default(uuid())
  companyId   String
  url         String
  title       String?
  altText     String?
  sortOrder   Int                    @default(0)
  moderationStatus GalleryModerationStatus @default(PENDING)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([moderationStatus])
  @@index([companyId, sortOrder])
}

model GoCashTransaction {
  id            String                @id @default(uuid())
  companyId     String
  userId        String?
  type          GoCashTransactionType
  amount        Int
  balanceBefore Int                   @default(0)
  balanceAfter  Int                   @default(0)
  reason        String?
  sourceModule  String?
  redemptionType GoCashRedemptionType?
  referenceId   String?
  createdAt     DateTime              @default(now())

  company       Company               @relation(fields: [companyId], references: [id], onDelete: NoAction)

  @@index([companyId])
  @@index([type])
  @@index([createdAt])
  @@index([companyId, createdAt])
  @@unique([companyId, type, reason])
}

model SellerAnalyticsEvent {
  id          String             @id @default(uuid())
  companyId   String
  userId      String?
  eventType   AnalyticsEventType
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime           @default(now())

  company     Company            @relation(fields: [companyId], references: [id], onDelete: NoAction)

  @@index([companyId])
  @@index([eventType])
  @@index([createdAt])
  @@index([companyId, createdAt])
}

model SubscriptionEvent {
  id              String               @id @default(uuid())
  companyId       String
  status          SubscriptionStatus
  planType        PlanType?
  alertPeriod     SubscriptionAlertPeriod?
  alertSentAt     DateTime?
  graceEndAt      DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())

  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model Product {
  id                  String        @id @default(uuid())
  companyId           String
  categoryId          String?
  industryId          String?
  productMasterId     String?
  name                String
  slug                String        @unique
  shortDescription    String?
  description         String?
  productType         ProductType   @default(PHYSICAL)
  status              ProductStatus @default(DRAFT)
  brand               String?
  model               String?
  sku                 String?
  moq                 Int           @default(1)
  unit                String?
  visibilityRadius    GeographicReach?
  isFeatured          Boolean       @default(false)
  isBestseller        Boolean       @default(false)
  originalPrice       Decimal?      @db.Decimal(12, 2)
  viewCount           Int           @default(0)
  savedCount          Int           @default(0)
  monthlyOrders       Int           @default(0)
  videoUrl            String?
  maxOrderQty         Int?
  deliveryEta         String?
  freeDeliveryAbove   Decimal?      @db.Decimal(12, 2)
  gstInvoiceAvailable Boolean       @default(true)
  tradeCreditEligible Boolean       @default(false)
  returnPolicy        String?
  trustScoreSnapshot  Int           @default(0)
  latitude            Float?
  longitude           Float?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  createdBy           String
  updatedBy           String?

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  industry          Industry?            @relation(fields: [industryId], references: [id], onDelete: SetNull)
  productMaster     ProductMaster? @relation(fields: [productMasterId], references: [id], onDelete: SetNull)
  claim             ProductClaim?  @relation("ProductClaimProduct")
  media             ProductMedia[]
  specifications    ProductSpecification[]
  variants          ProductVariant[]
  inventory         ProductInventory?
  priceSlabs        ProductPriceSlab[]
  reviews           ProductReview[]
  qa                ProductQa[]
  savedBy           SavedProduct[]
  attachments       ProductAttachment[]
  attributes        ProductAttribute[]
  locationIndex     ProductLocationIndex?

  @@index([slug])
  @@index([companyId])
  @@index([categoryId])
  @@index([industryId])
  @@index([productMasterId])
  @@index([status])
  @@index([productType])
  @@index([trustScoreSnapshot])
  @@index([deletedAt])
}

model ProductMedia {
  id        String    @id @default(uuid())
  productId String
  type      MediaType @default(IMAGE)
  url       String
  title     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
}

model ProductAttachment {
  id          String   @id @default(uuid())
  claimId     String?
  productId   String?
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  type        String   @default("IMAGE")
  uploadedBy  String
  createdAt   DateTime @default(now())

  claim       ProductClaim? @relation(fields: [claimId], references: [id], onDelete: Cascade)
  product     Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([productId])
}

model ProductSpecification {
  id        String @id @default(uuid())
  productId String
  key       String
  label     String?
  value     String
  sortOrder Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([key])
}

model ProductVariant {
  id          String       @id @default(uuid())
  productId   String
  variantType VariantType
  customName  String?
  value       String
  sku         String?
  price       Decimal?     @db.Decimal(12, 2)
  compareAtPrice Decimal?  @db.Decimal(12, 2)
  currency    String       @default("INR")
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory   VariantInventory?

  @@index([productId])
  @@index([variantType])
  @@index([sku])
}

model VariantInventory {
  id                String      @id @default(uuid())
  variantId         String      @unique
  availableQuantity Int         @default(0)
  reservedQuantity  Int         @default(0)
  minimumThreshold  Int         @default(5)
  stockStatus       StockStatus @default(OUT_OF_STOCK)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model ProductInventory {
  id                String      @id @default(uuid())
  productId         String      @unique
  availableQuantity Int         @default(0)
  reservedQuantity  Int         @default(0)
  minimumThreshold  Int         @default(5)
  stockStatus       StockStatus @default(OUT_OF_STOCK)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPriceSlab {
  id        String   @id @default(uuid())
  productId String
  minQty    Int
  maxQty    Int?
  price     Decimal  @db.Decimal(12, 2)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([minQty])
}

model VendorCodeSequence {
  id        String   @id @default(uuid())
  prefix    String
  period    String
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prefix, period])
  @@index([prefix, period])
}

model CodeAttribution {
  id              String   @id @default(uuid())
  code            String   @unique
  codeType        String
  leadCount       Int      @default(0)
  revenueAttribution Decimal @default(0)
  sellerCount     Int      @default(0)
  buyerCount      Int      @default(0)
  commissionAmount Decimal  @default(0)
  rmOwnerId       String?
  meOwnerId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rmOwner         User?    @relation("RMAttributions", fields: [rmOwnerId], references: [id], onDelete: SetNull)
  meOwner         User?    @relation("MEAttributions", fields: [meOwnerId], references: [id], onDelete: SetNull)

  @@index([codeType])
  @@index([rmOwnerId])
  @@index([meOwnerId])
}

model RecentSearch {
  id        String   @id @default(uuid())
  userId    String
  query     String
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@index([userId, timestamp])
}

// ─────────────────────────────────────────────────────
// RFQ + TRADMATCH — Phase 3A.7
// ─────────────────────────────────────────────────────

model Rfq {
  id              String        @id @default(uuid())
  companyId       String
  userId          String?
  categoryId      String?
  industryId      String?
  rfqNumber       String?       @unique
  stateCode       String?
  title           String
  description     String?
  rfqType         RfqType
  visibility      RfqVisibility  @default(PUBLIC)
  urgency         RfqUrgency     @default(NORMAL)
  status          RfqStatus      @default(DRAFT)
  budgetMin       Decimal?       @db.Decimal(14, 2)
  budgetMax       Decimal?       @db.Decimal(14, 2)
  showBudget      Boolean        @default(false)
  currency        String         @default("INR")
  quantity        Int?
  unit            String?
  preferredLocation String?
  expiresAt       DateTime?
  matchedCount    Int            @default(0)
  quoteCount      Int            @default(0)
  acceptedQuoteId String?        @unique
  convertedAt     DateTime?
  closedAt        DateTime?
  closedBy        String?
  reopenedAt      DateTime?
  reopenCount     Int            @default(0)
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?

  company         Company          @relation("BuyerRfqs", fields: [companyId], references: [id], onDelete: Restrict)
  user            User?            @relation("RfqCreators", fields: [userId], references: [id], onDelete: SetNull)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  industry        Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  locations       RfqLocation[]
  attachments     RfqAttachment[]
  productItems    RfqProductItem[]
  vendorMatches   RfqVendorMatch[]
  quotes          Quote[]          @relation("RfqQuotes")
  analyticsEvents RfqAnalyticsEvent[]
  orders          Order[]          @relation("RfqOrders")

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([rfqNumber])
  @@index([stateCode])
}

model RfqLocation {
  id        String   @id @default(uuid())
  rfqId     String
  city      String
  state     String?
  country   String   @default("India")
  pincode   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  rfq       Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model RfqAttachment {
  id           String            @id @default(uuid())
  rfqId        String
  type         RfqAttachmentType
  url          String
  originalName String?
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime          @default(now())

  rfq          Rfq               @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([type])
}

model RfqProductItem {
  id          String   @id @default(uuid())
  rfqId       String
  categoryId  String?
  productName String
  description String?
  quantity    Int?
  unit        String?
  targetPrice Decimal? @db.Decimal(14, 2)
  isService   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  quoteLineItems QuoteLineItem[]

  @@index([rfqId])
  @@index([categoryId])
}

model RfqVendorMatch {
  id            String      @id @default(uuid())
  rfqId         String
  companyId     String
  matchScore    Decimal     @db.Decimal(5, 4)
  categoryScore Decimal?    @db.Decimal(5, 4)
  geoScore      Decimal?    @db.Decimal(5, 4)
  trustScore    Decimal?    @db.Decimal(5, 4)
  responseScore Decimal?    @db.Decimal(5, 4)
  tradgoScore   Decimal?    @db.Decimal(5, 4)
  planScore     Decimal?    @db.Decimal(5, 4)
  matchFactors  Json?
  status        MatchStatus @default(PENDING)
  sentAt        DateTime?
  matchedAt     DateTime?
  viewedAt      DateTime?
  declinedAt    DateTime?
  declineReason String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  rfq           Rfq         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  company       Company     @relation("MatchedSellers", fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([rfqId, companyId])
  @@index([rfqId])
  @@index([companyId, status])
  @@index([matchScore])
}

model Quote {
  id               String        @id @default(uuid())
  rfqId            String
  companyId        String
  userId           String?
  status           QuoteStatus   @default(DRAFT)
  currency         String        @default("INR")
  subtotal         Decimal?      @db.Decimal(14, 2)
  taxAmount        Decimal?      @db.Decimal(14, 2)
  totalAmount      Decimal?      @db.Decimal(14, 2)
  discountAmount   Decimal?      @db.Decimal(14, 2)
  discountPercent  Decimal?      @db.Decimal(5, 2)
  deliveryTerms    DeliveryTerms?
  paymentTerms     PaymentTerms?
  leadTimeDays     Int?
  leadTimeDisplay  String?
  validityDate     DateTime?
  notes            String?
  quoteVersion     Int           @default(1)
  revisionComment  String?
  isSeen           Boolean       @default(false)
  seenAt           DateTime?
  submittedAt      DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  acceptedAt       DateTime?
  withdrawnAt      DateTime?
  withdrawReason   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  createdBy        String
  updatedBy        String?

  rfq              Rfq           @relation("RfqQuotes", fields: [rfqId], references: [id], onDelete: Restrict)
  company          Company       @relation("SellerQuotes", fields: [companyId], references: [id], onDelete: Restrict)
  user             User?         @relation("QuoteCreators", fields: [userId], references: [id], onDelete: SetNull)
  lineItems        QuoteLineItem[]
  attachments      QuoteAttachment[]

  @@index([rfqId, companyId])
  @@index([rfqId, status])
  @@index([companyId, createdAt])
  @@index([status, createdAt])
  events           QuoteEvent[]
  orders           Order[]          @relation("QuoteOrders")
  @@index([deletedAt])
}

model QuoteLineItem {
  id               String        @id @default(uuid())
  quoteId          String
  rfqProductItemId String?
  productName      String
  description      String?
  quantity         Int?
  unit             String?
  unitPrice        Decimal       @db.Decimal(14, 2)
  totalPrice       Decimal?      @db.Decimal(14, 2)
  deliveryTerms    DeliveryTerms?
  leadTimeDays     Int?
  notes            String?
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  quote            Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqProductItem   RfqProductItem? @relation(fields: [rfqProductItemId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}

model QuoteAttachment {
  id           String            @id @default(uuid())
  quoteId      String
  type         RfqAttachmentType
  url          String
  originalName String?
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime          @default(now())

  quote        Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuoteEvent {
  id        String         @id @default(uuid())
  quoteId   String
  companyId String
  eventType QuoteEventType
  metadata  Json?
  createdAt DateTime       @default(now())

  quote     Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([quoteId, eventType])
}

model RfqCreditLedger {
  id            String              @id @default(uuid())
  companyId     String
  type          CreditTransactionType
  amount        Int
  balanceBefore Int                 @default(0)
  balanceAfter  Int                 @default(0)
  referenceId   String?
  description   String?
  packId        String?
  createdAt     DateTime            @default(now())

  company       Company             @relation(fields: [companyId], references: [id], onDelete: NoAction)
  pack          RfqCreditPack?      @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([type])
  @@unique([companyId, type, referenceId])
}

model RfqCreditPack {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  credits      Int
  price        Decimal  @db.Decimal(12, 2)
  currency     String   @default("INR")
  validityDays Int?
  isActive     Boolean  @default(true)
  purchasedAt  DateTime @default(now())
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  ledgers      RfqCreditLedger[]
  payments     Payment[]

  @@index([companyId])
  @@index([isActive])
}

model RfqAnalytics {
  id                       String   @id @default(uuid())
  companyId                String   @unique
  totalRfqsReceived        Int      @default(0)
  totalQuotesSubmitted     Int      @default(0)
  totalRfqWon              Int      @default(0)
  totalRfqConverted        Int      @default(0)
  totalRfqRevenue          Decimal  @default(0) @db.Decimal(16, 2)
  averageResponseTimeHours Float    @default(0)
  rfqWinRate               Float    @default(0)
  quoteConversionRate      Float    @default(0)
  lastRfqAt                DateTime?
  lastQuoteAt              DateTime?
  calculatedAt             DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  company                  Company  @relation(fields: [companyId], references: [id], onDelete: NoAction)

  @@index([companyId])
}

model RfqAnalyticsEvent {
  id        String                @id @default(uuid())
  companyId String
  rfqId     String
  eventType RfqAnalyticsEventType
  metadata  Json?
  createdAt DateTime              @default(now())

  company   Company               @relation(fields: [companyId], references: [id], onDelete: NoAction)
  rfq       Rfq                   @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([rfqId])
  @@index([eventType, createdAt])
}

model RfqNumberCounter {
  id        String @id
  stateCode String
  date      String
  seq       Int    @default(0)

  @@unique([stateCode, date])
}

enum OrderSource {
  RFQ
  QUOTE
  DIRECT
  CART
  REPEAT
  CUSTOM
}

enum OrderType {
  PRODUCT
  SERVICE
  BULK
  REPEAT
  CUSTOM
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DISPATCHED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
}

enum CancellationActor {
  BUYER
  SELLER
  ADMIN
}

enum CancellationReason {
  STOCK_UNAVAILABLE
  PRICE_ISSUE
  BUYER_REQUEST
  LOGISTICS_ISSUE
  OTHER
}

enum DeliveryMethod {
  PICKUP
  SELLER_DELIVERY
  THIRD_PARTY_LOGISTICS
  BUYER_ARRANGED
}

enum ReturnReason {
  QUALITY_ISSUE
  QUANTITY_ISSUE
  WRONG_PRODUCT
  LATE_DELIVERY
  PAYMENT_ISSUE
  SERVICE_ISSUE
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum ConversationType {
  DIRECT
  RFQ_NEGOTIATION
  ORDER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
  SYSTEM
}

enum ParticipantRole {
  MEMBER
  ADMIN
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  ORDER_PAYMENT
  CREDIT_PACK_PURCHASE
  SUBSCRIPTION
  REFUND
  PAYOUT
}

enum FileScanStatus {
  PENDING
  SCANNING
  CLEAN
  INFECTED
  QUARANTINED
  FAILED
}

model Conversation {
  id              String                   @id @default(uuid())
  type            ConversationType
  title           String?
  rfqId           String?
  orderId         String?
  createdBy       String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  participants    ConversationParticipant[]
  messages        Message[]
  blockedUsers    BlockedUser[]

  @@index([rfqId])
  @@index([orderId])
  @@index([createdAt])
}

model ConversationParticipant {
  id              String          @id @default(uuid())
  conversationId  String
  companyId       String
  userId          String
  role            ParticipantRole @default(MEMBER)
  joinedAt        DateTime        @default(now())
  leftAt          DateTime?
  lastReadAt      DateTime?
  isOnline        Boolean         @default(false)
  lastSeenAt      DateTime?

  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String             @id @default(uuid())
  conversationId  String
  senderId        String
  senderCompanyId String
  type            MessageType        @default(TEXT)
  content         String?
  replyToId       String?
  isDeleted       Boolean            @default(false)
  deliveredAt     DateTime?
  seenAt          DateTime?
  createdAt       DateTime           @default(now())

  conversation    Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo         Message?           @relation("ReplyChain", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]          @relation("ReplyChain")
  attachments     MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageAttachment {
  id              String    @id @default(uuid())
  messageId       String
  type            String
  url             String
  originalName    String?
  mimeType        String?
  fileSize        Int?
  width           Int?
  height          Int?
  duration        Int?
  createdAt       DateTime  @default(now())

  message         Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model BlockedUser {
  id              String       @id @default(uuid())
  conversationId  String
  blockedById     String
  blockedUserId   String
  reason          String?
  createdAt       DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, blockedUserId])
}

model ReportedMessage {
  id              String    @id @default(uuid())
  messageId       String
  reportedById    String
  reason          String
  description     String?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
}

model ChatEvent {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([type, createdAt])
}

model OrderNumberCounter {
  id        String @id
  stateCode String
  date      String
  seq       Int    @default(0)

  @@unique([stateCode, date])
}

model Order {
  id                  String             @id @default(uuid())
  orderNumber         String             @unique
  stateCode           String
  idempotencyKey      String?            @unique
  source              OrderSource
  type                OrderType
  status              OrderStatus        @default(PENDING)
  statusChangedAt     DateTime           @default(now())
  statusChangedBy     String
  buyerCompanyId      String
  sellerCompanyId     String
  rfqId               String?
  quoteId             String?
  title               String?
  description         String?
  currency            String             @default("INR")
  subtotal            Decimal
  taxAmount           Decimal?
  discountAmount      Decimal?
  totalAmount         Decimal
  quantity            Int
  unit                String?
  deliveryMethod      DeliveryMethod?
  trackingNumber      String?
  transporterName     String?
  vehicleNumber       String?
  lrNumber            String?
  ewayBillNumber      String?
  deliveryAddress     Json?
  expectedDeliveryDate DateTime?
  deliveredAt         DateTime?
  buyerNotes          String?
  sellerNotes         String?
  createdBy           String
  updatedBy           String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  buyerCompany        Company            @relation("OrderBuyer", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany       Company            @relation("OrderSeller", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  rfq                 Rfq?               @relation("RfqOrders", fields: [rfqId], references: [id], onDelete: SetNull)
  quote               Quote?             @relation("QuoteOrders", fields: [quoteId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  locations           OrderLocation[]
  timeline            OrderTimelineEvent[]
  documents           OrderDocument[]
  cancellations       OrderCancellation[]
  returns             OrderReturn[]
  payments            Payment[]
  escrow              Escrow?
  disputes            Dispute[]

  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
  @@index([createdAt])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String?
  productName       String
  sku               String?
  quantity          Int
  reservedQuantity  Int      @default(0)
  deliveredQuantity Int      @default(0)
  unitPrice         Decimal
  totalPrice        Decimal
  taxPercent        Decimal?
  taxAmount         Decimal?
  createdAt         DateTime @default(now())

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderLocation {
  id                  String       @id @default(uuid())
  orderId             String
  type                LocationType
  address             String
  city                String
  state               String
  country             String       @default("India")
  pincode             String?
  contactName         String?
  contactPhone        String?
  isDeliveryLocation  Boolean      @default(false)
  deliveryStatus      String       @default("PENDING")
  dispatchedAt        DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime     @default(now())

  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderTimelineEvent {
  id            String       @id @default(uuid())
  orderId       String
  fromStatus    OrderStatus?
  toStatus      OrderStatus
  changedBy     String
  changedByRole String?
  note          String?
  createdAt     DateTime     @default(now())

  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
}

model OrderDocument {
  id           String     @id @default(uuid())
  orderId      String
  docType      String
  fileName     String
  fileUrl      String
  mimeType     String?
  fileSize     Int?
  version      Int        @default(1)
  uploadedBy   String
  createdAt    DateTime   @default(now())

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@unique([orderId, docType, version])
}

model OrderCancellation {
  id                  String             @id @default(uuid())
  orderId             String
  reason              CancellationReason
  reasonText          String?
  cancelledBy         String
  actor               CancellationActor
  statusBeforeCancel  OrderStatus
  approvedAt          DateTime?
  approvedBy          String?
  note                String?
  createdAt           DateTime           @default(now())

  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderReturn {
  id              String       @id @default(uuid())
  orderId         String
  itemId          String?
  reason          ReturnReason
  description     String?
  status          ReturnStatus @default(PENDING)
  quantity        Int?
  refundAmount    Decimal?
  requestedBy     String
  requestedByRole String
  reviewedBy      String?
  reviewedAt      DateTime?
  adminNote       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refund          Refund?

  @@index([orderId])
  @@index([status])
}

model OrderAnalyticsEvent {
  id        String   @id @default(uuid())
  companyId String
  orderId   String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([eventType])
  @@index([createdAt])
}

model Payment {
  id              String         @id @default(uuid())
  companyId       String
  type            PaymentType
  gateway         PaymentGateway @default(RAZORPAY)
  status          PaymentStatus  @default(PENDING)
  gatewayOrderId  String?
  gatewayPaymentId String?
  gatewaySignature String?
  amount          Int
  currency        String         @default("INR")
  fee             Int?
  tax             Int?
  description     String?
  notes           Json?
  orderId         String?
  rfqCreditPackId String?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company        @relation(fields: [companyId], references: [id])
  order           Order?         @relation(fields: [orderId], references: [id])
  rfqCreditPack   RfqCreditPack? @relation(fields: [rfqCreditPackId], references: [id])
  refunds         Refund[]
  invoice         Invoice?
  manualPaymentProof ManualPaymentProof?

  @@index([companyId])
  @@index([orderId])
  @@index([gatewayOrderId])
  @@index([gatewayPaymentId])
  @@index([status])
}

model Refund {
  id              String       @id @default(uuid())
  paymentId       String
  gatewayRefundId String?
  amount          Int
  reason          String?
  status          String       @default("PENDING")
  orderReturnId   String?       @unique
