model Order {
  id                  String             @id @default(uuid())
  orderNumber         String             @unique
  stateCode           String
  idempotencyKey      String?            @unique
  source              OrderSource
  type                OrderType
  status              OrderStatus        @default(PENDING)
  statusChangedAt     DateTime           @default(now())
  statusChangedBy     String
  buyerCompanyId      String
  sellerCompanyId     String
  rfqId               String?
  quoteId             String?
  title               String?
  description         String?
  currency            String             @default("INR")
  subtotal            Decimal
  taxAmount           Decimal?
  discountAmount      Decimal?
  totalAmount         Decimal
  quantity            Int
  unit                String?
  deliveryMethod      DeliveryMethod?
  trackingNumber      String?
  transporterName     String?
  vehicleNumber       String?
  lrNumber            String?
  ewayBillNumber      String?
  deliveryAddress     Json?
  expectedDeliveryDate DateTime?
  deliveredAt         DateTime?
  buyerNotes          String?
  sellerNotes         String?
  createdBy           String
  updatedBy           String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  buyerCompany        Company            @relation("OrderBuyer", fields: [buyerCompanyId], references: [id], onDelete: Restrict)
  sellerCompany       Company            @relation("OrderSeller", fields: [sellerCompanyId], references: [id], onDelete: Restrict)
  rfq                 Rfq?               @relation("RfqOrders", fields: [rfqId], references: [id], onDelete: SetNull)
  quote               Quote?             @relation("QuoteOrders", fields: [quoteId], references: [id], onDelete: SetNull)
  purchaseOrderId     String?
  purchaseOrder       PurchaseOrder?     @relation("PoOrders", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  locations           OrderLocation[]
  timeline            OrderTimelineEvent[]
  documents           OrderDocument[]
  cancellations       OrderCancellation[]
  returns             OrderReturn[]
  payments            Payment[]
  escrow              Escrow?
  disputes            Dispute[]
  shipments           Shipment[]        @relation("OrderShipments")
  deliveries          Delivery[]        @relation("OrderDeliveries")

  @@index([buyerCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
  @@index([createdAt])
  @@index([rfqId])
  @@index([quoteId])
  @@index([purchaseOrderId])
  @@index([buyerCompanyId, status])
  @@index([sellerCompanyId, status])
}

model OrderItem {
